@page "/chat"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IChatApiService ChatApiService
@inject IJSRuntime JS
@inject DialogService DialogService
@using Biotrackr.UI.Telemetry
@using Markdig
@using ChatMessage = Biotrackr.UI.Models.Chat.ChatMessage

<PageTitle>Biotrackr - Chat</PageTitle>

<RadzenMediaQuery Query="(max-width: 768px)" Change="@(matches => { _isMobile = matches; StateHasChanged(); })" />

<div class="chat-container">
    @if (!_isMobile)
    {
        <nav class="chat-sidebar-panel" aria-label="Conversations">
            <ChatSidebar Conversations="_conversations"
                         CurrentSessionId="_currentSessionId"
                         IsStreaming="_isStreaming"
                         IsLoading="_isLoadingConversations"
                         HasMore="_hasMoreConversations"
                         OnSelectConversation="LoadConversation"
                         OnDeleteConversation="DeleteConversation"
                         OnNewConversation="StartNewConversation"
                         OnLoadMore="LoadMoreConversations" />
        </nav>
    }

    <div class="chat-main">
        @if (_isMobile)
        {
            <RadzenStack Orientation="Orientation.Horizontal" class="rz-p-2">
                <RadzenButton Icon="menu" Variant="Variant.Text" Click="OpenMobileSidebar" aria-label="Open conversations" />
            </RadzenStack>
        }

        <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" ShowIcon="true" AllowClose="false" class="rz-mb-0">
            This AI assistant provides data summaries only. It is not medical advice. Always consult a healthcare professional.
        </RadzenAlert>

        <ErrorDisplay Message="@_errorMessage" />

        <div class="chat-messages" @ref="_messagesContainer">
            @if (_messages.Count == 0 && !_isStreaming)
            {
                <div class="chat-empty-state">
                    <RadzenIcon Icon="chat_bubble_outline" Style="font-size: 48px;" />
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mt-2">Ask about your health data</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">
                        Try one of these prompts to get started:
                    </RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap"
                                 Gap="0.5rem" JustifyContent="JustifyContent.Center" class="rz-mt-3">
                        @foreach (var suggestion in _suggestions)
                        {
                            <RadzenButton Text="@suggestion" Variant="Variant.Outlined"
                                          ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small"
                                          Click="@(() => SendSuggestion(suggestion))"
                                          aria-label="@($"Send suggestion: {suggestion}")" />
                        }
                    </RadzenStack>
                </div>
            }
            else
            {
                @foreach (var message in _messages)
                {
                    <div @key="@message.Timestamp" class="message @(message.Role == "user" ? "message-user" : "message-agent")">
                        @if (message.Role == "assistant")
                        {
                            <div class="message-content markdown-body">@RenderMarkdown(message.Content)</div>
                        }
                        else
                        {
                            <div class="message-content">@message.Content</div>
                        }
                        @if (message.Role == "assistant" && message.ToolCalls is { Count: > 0 })
                        {
                            <div class="message-tool-badges">
                                @foreach (var tool in message.ToolCalls)
                                {
                                    <RadzenBadge Text="@tool" BadgeStyle="BadgeStyle.Info" IsPill="true" class="rz-mr-1" />
                                }
                            </div>
                        }
                        <div class="message-timestamp">@message.Timestamp.ToString("HH:mm")</div>
                    </div>
                }

                @if (_isStreaming)
                {
                    <div class="message message-agent">
                        @if (!string.IsNullOrEmpty(_currentResponse))
                        {
                            <div class="message-content markdown-body">@RenderMarkdown(_currentResponse)</div>
                        }
                        @if (_reportGenerating)
                        {
                            <div class="report-progress" role="status" aria-label="Report generation in progress">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                    <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate"
                                                               Size="ProgressBarCircularSize.ExtraSmall"
                                                               ProgressBarStyle="ProgressBarStyle.Info"
                                                               ShowValue="false" />
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-info">
                                        Generating report...
                                    </RadzenText>
                                    <RadzenBadge Text="@FormatElapsedTime(_reportElapsedSeconds)"
                                                 BadgeStyle="BadgeStyle.Light" IsPill="true" />
                                </RadzenStack>
                            </div>
                        }
                        else
                        {
                            <div class="typing-indicator">
                                <span></span><span></span><span></span>
                            </div>
                        }
                    </div>
                }
            }
        </div>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="chat-input-area">
            <RadzenTextBox @bind-Value="_inputMessage" Placeholder="Type a message..." Disabled="@_isStreaming" class="rz-flex-grow-1" @onkeydown="HandleKeyDown" />
            <RadzenButton Text="Send" Icon="send" Click="SendMessage" Disabled="@(_isStreaming || string.IsNullOrWhiteSpace(_inputMessage))" ButtonStyle="ButtonStyle.Primary" />
        </RadzenStack>
    </div>
</div>

@code {
    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private readonly Dictionary<int, MarkupString> _markdownCache = new();
    private PeriodicTimer? _renderTimer;
    private CancellationTokenSource? _renderCts;
    private bool _disposed;
    private bool _isMobile;

    private List<ChatMessage> _messages = [];
    private List<ChatConversationSummary> _conversations = [];
    private string? _currentSessionId;
    private bool _isStreaming;
    private string _currentResponse = string.Empty;
    private List<string> _currentToolCalls = [];
    private string _inputMessage = string.Empty;
    private string? _errorMessage;
    private bool _isLoadingConversations;
    private bool _hasMoreConversations;
    private int _conversationPage = 1;
    private ElementReference _messagesContainer;
    private bool _reportGenerating;
    private int _reportElapsedSeconds;
    private PeriodicTimer? _reportTimer;
    private CancellationTokenSource? _reportTimerCts;

    private static readonly string[] _suggestions =
    [
        "How many steps did I take yesterday?",
        "Summarize my sleep quality this week",
        "Compare my calories this week vs last",
        "What's my weight trend over the past month?"
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadConversationsList();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_inputMessage) || _isStreaming)
            return;

        var messageText = _inputMessage.Trim();
        _inputMessage = string.Empty;
        _errorMessage = null;

        _messages.Add(new ChatMessage
        {
            Role = "user",
            Content = messageText,
            Timestamp = DateTime.UtcNow
        });

        _isStreaming = true;
        _currentResponse = string.Empty;
        _currentToolCalls = [];
        StateHasChanged();

        if (_currentSessionId is null)
        {
            _currentSessionId = Guid.NewGuid().ToString();
            ChatTelemetry.ConversationsCreated.Add(1);
        }

        _renderCts = new CancellationTokenSource();
        _renderTimer = new PeriodicTimer(TimeSpan.FromMilliseconds(80));
        _ = RenderLoopAsync(_renderCts.Token);

        try
        {
            await foreach (var evt in ChatApiService.SendMessageAsync(_currentSessionId, messageText))
            {
                switch (evt.Type)
                {
                    case "TEXT_MESSAGE_CONTENT":
                        _currentResponse += evt.Delta;
                        break;

                    case "RUN_STARTED":
                        if (evt.ThreadId is not null)
                        {
                            _currentSessionId = evt.ThreadId;
                        }
                        break;

                    case "TOOL_CALL_START":
                        if (evt.Delta is not null)
                        {
                            _currentToolCalls.Add(evt.Delta);
                        }
                        if (evt.Delta is "RequestReport" && !_reportGenerating)
                        {
                            _reportGenerating = true;
                            _reportElapsedSeconds = 0;
                            _reportTimerCts = new CancellationTokenSource();
                            _reportTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
                            _ = ReportElapsedLoopAsync(_reportTimerCts.Token);
                        }
                        break;

                    case "TOOL_CALL_RESULT":
                        break;

                    case "RUN_FINISHED":
                        if (evt.ThreadId is not null)
                        {
                            _currentSessionId = evt.ThreadId;
                        }
                        StopReportTimer();
                        break;

                    case "RUN_ERROR":
                        StopReportTimer();
                        break;
                }
            }

            if (!string.IsNullOrEmpty(_currentResponse))
            {
                _messages.Add(new ChatMessage
                {
                    Role = "assistant",
                    Content = _currentResponse,
                    Timestamp = DateTime.UtcNow,
                    ToolCalls = _currentToolCalls.Count > 0 ? _currentToolCalls : null
                });
            }
        }
        catch (Exception)
        {
            _errorMessage = "Failed to get a response. Please try again.";
        }
        finally
        {
            _renderCts?.Cancel();
            _renderTimer?.Dispose();
            _renderTimer = null;
            StopReportTimer();
            _isStreaming = false;
            _currentResponse = string.Empty;
            _currentToolCalls = [];
            StateHasChanged();
        }

        await LoadConversationsList();
        await ScrollToBottom();
    }

    private async Task SendSuggestion(string text)
    {
        _inputMessage = text;
        await SendMessage();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task LoadConversation(string sessionId)
    {
        if (_isStreaming || sessionId == _currentSessionId)
            return;

        _errorMessage = null;
        var conversation = await ChatApiService.GetConversationAsync(sessionId);
        if (conversation is not null)
        {
            _currentSessionId = conversation.SessionId;
            _messages = conversation.Messages;
            StateHasChanged();
            await ScrollToBottom();
        }
        else
        {
            _errorMessage = "Could not load conversation.";
        }
    }

    private void StartNewConversation()
    {
        _currentSessionId = null;
        _messages = [];
        _currentResponse = string.Empty;
        _currentToolCalls = [];
        _errorMessage = null;
        _inputMessage = string.Empty;
    }

    private async Task DeleteConversation(string sessionId)
    {
        if (_isStreaming)
            return;

        await ChatApiService.DeleteConversationAsync(sessionId);
        _conversations.RemoveAll(c => c.SessionId == sessionId);

        if (_currentSessionId == sessionId)
        {
            StartNewConversation();
        }

        StateHasChanged();
    }

    private async Task LoadConversationsList()
    {
        _isLoadingConversations = true;
        _conversationPage = 1;

        var result = await ChatApiService.GetConversationsAsync(pageNumber: 1, pageSize: 20);
        _conversations = result.Items;
        _hasMoreConversations = result.HasNextPage;

        _isLoadingConversations = false;
    }

    private async Task LoadMoreConversations()
    {
        _conversationPage++;
        var result = await ChatApiService.GetConversationsAsync(pageNumber: _conversationPage, pageSize: 20);
        _conversations.AddRange(result.Items);
        _hasMoreConversations = result.HasNextPage;
        StateHasChanged();
    }

    private MarkupString RenderMarkdown(string content)
    {
        var hash = content.GetHashCode();
        if (!_markdownCache.TryGetValue(hash, out var cached))
        {
            cached = new MarkupString(Markdown.ToHtml(content, MarkdownPipeline));
            _markdownCache[hash] = cached;
        }
        return cached;
    }

    private async Task RenderLoopAsync(CancellationToken ct)
    {
        try
        {
            while (await _renderTimer!.WaitForNextTickAsync(ct))
            {
                if (_disposed) return;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task ReportElapsedLoopAsync(CancellationToken ct)
    {
        try
        {
            while (await _reportTimer!.WaitForNextTickAsync(ct))
            {
                if (_disposed) return;
                _reportElapsedSeconds++;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private void StopReportTimer()
    {
        _reportGenerating = false;
        _reportTimerCts?.Cancel();
        _reportTimerCts?.Dispose();
        _reportTimerCts = null;
        _reportTimer?.Dispose();
        _reportTimer = null;
    }

    private async Task OpenMobileSidebar()
    {
        await DialogService.OpenSideAsync<ChatSidebar>(
            "Conversations",
            new Dictionary<string, object?>
            {
                { "Conversations", _conversations },
                { "CurrentSessionId", _currentSessionId! },
                { "IsStreaming", _isStreaming },
                { "IsLoading", _isLoadingConversations },
                { "HasMore", _hasMoreConversations },
                { "OnSelectConversation", EventCallback.Factory.Create<string>(this, LoadConversation) },
                { "OnDeleteConversation", EventCallback.Factory.Create<string>(this, DeleteConversation) },
                { "OnNewConversation", EventCallback.Factory.Create(this, StartNewConversation) },
                { "OnLoadMore", EventCallback.Factory.Create(this, LoadMoreConversations) }
            },
            new SideDialogOptions
            {
                Position = DialogPosition.Left,
                ShowMask = true,
                Width = "280px",
                CloseDialogOnOverlayClick = true,
                CanClose = () => Task.FromResult(!_isStreaming)
            });
    }

    private static string FormatElapsedTime(int totalSeconds)
    {
        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;
        return minutes > 0 ? $"{minutes}:{seconds:D2}" : $"{seconds}s";
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "document.querySelector('[class*=chat-messages]')?.scrollTo(0, document.querySelector('[class*=chat-messages]')?.scrollHeight)");
        }
        catch
        {
            // JS interop may fail during prerendering
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _renderCts?.Cancel();
        _renderCts?.Dispose();
        _renderTimer?.Dispose();
        _reportTimerCts?.Cancel();
        _reportTimerCts?.Dispose();
        _reportTimer?.Dispose();
    }
}
