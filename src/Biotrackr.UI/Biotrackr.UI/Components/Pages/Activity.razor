@page "/activity"
@rendermode InteractiveServer
@inject IBiotrackrApiService ApiService

<PageTitle>Biotrackr - Activity</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Activity</RadzenText>

<DatePicker SelectedDate="@_selectedDate" StartDate="@_startDate" EndDate="@_endDate" Mode="@_mode"
            OnSingleDateSelected="LoadByDate" OnDateRangeSelected="LoadByRange" />

<LoadingSpinner IsLoading="@_isLoading" Message="Loading activity data..." />
<ErrorDisplay Message="@_errorMessage" />

@if (!_isLoading && _singleItem is not null && _mode == "date")
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Steps" Value="@(_singleItem.Activity.Summary.Steps.ToString("N0"))" 
                         Subtitle="@GetGoalProgress(_singleItem.Activity.Summary.Steps, _singleItem.Activity.Goals.Steps)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Calories Burned" Value="@(_singleItem.Activity.Summary.CaloriesOut.ToString("N0"))"
                         Subtitle="@GetGoalProgress(_singleItem.Activity.Summary.CaloriesOut, _singleItem.Activity.Goals.CaloriesOut)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Active Minutes" Value="@((_singleItem.Activity.Summary.FairlyActiveMinutes + _singleItem.Activity.Summary.VeryActiveMinutes).ToString("N0"))"
                         Subtitle="@GetGoalProgress(_singleItem.Activity.Summary.FairlyActiveMinutes + _singleItem.Activity.Summary.VeryActiveMinutes, _singleItem.Activity.Goals.ActiveMinutes)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Floors" Value="@(_singleItem.Activity.Summary.Floors.ToString("N0"))"
                         Subtitle="@GetGoalProgress(_singleItem.Activity.Summary.Floors, _singleItem.Activity.Goals.Floors)" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Goal Progress</RadzenText>
    <RadzenRow Gap="1rem" class="rz-mb-4" AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6" SizeSM="6">
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Subtitle2">Steps: @_singleItem.Activity.Summary.Steps.ToString("N0") / @_singleItem.Activity.Goals.Steps.ToString("N0")</RadzenText>
                <RadzenProgressBar Value="@GetGoalPercent(_singleItem.Activity.Summary.Steps, _singleItem.Activity.Goals.Steps)" ShowValue="true" Mode="ProgressBarMode.Determinate" Style="height: 20px;" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeSM="6">
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Subtitle2">Calories Burned: @_singleItem.Activity.Summary.CaloriesOut.ToString("N0") / @_singleItem.Activity.Goals.CaloriesOut.ToString("N0")</RadzenText>
                <RadzenProgressBar Value="@GetGoalPercent(_singleItem.Activity.Summary.CaloriesOut, _singleItem.Activity.Goals.CaloriesOut)" ShowValue="true" Mode="ProgressBarMode.Determinate" Style="height: 20px;" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    @if (_singleItem.Activity.Summary.HeartRateZones.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Heart Rate Zones Chart</RadzenText>
        <RadzenChart Style="height: 300px;" class="rz-mb-4">
            <RadzenBarSeries Data="@_singleItem.Activity.Summary.HeartRateZones" CategoryProperty="Name"
                ValueProperty="Minutes" Title="Minutes" />
            <RadzenCategoryAxis Padding="20" />
            <RadzenValueAxis>
                <RadzenGridLines Visible="true" />
            </RadzenValueAxis>
        </RadzenChart>
    }

    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Active Minutes Breakdown</RadzenText>
    <RadzenChart Style="height: 300px;" class="rz-mb-4">
        <RadzenBarSeries Data="@GetActiveMinutesBreakdown()" CategoryProperty="Category" ValueProperty="Minutes" Title="Minutes" />
        <RadzenCategoryAxis Padding="20" />
        <RadzenValueAxis>
            <RadzenGridLines Visible="true" />
        </RadzenValueAxis>
    </RadzenChart>

    @if (_singleItem.Activity.Summary.HeartRateZones.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Heart Rate Zones</RadzenText>
        <RadzenDataGrid Data="@_singleItem.Activity.Summary.HeartRateZones" TItem="HeartRateZone" Density="Density.Compact" AllowPaging="false" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="HeartRateZone" Property="Name" Title="Zone" />
                <RadzenDataGridColumn TItem="HeartRateZone" Property="Minutes" Title="Minutes" />
                <RadzenDataGridColumn TItem="HeartRateZone" Title="Calories">
                    <Template Context="zone">@zone.CaloriesOut.ToString("F1")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="HeartRateZone" Title="Range (bpm)">
                    <Template Context="zone">@zone.Min - @zone.Max</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }

    @if (_singleItem.Activity.Activities.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Activities</RadzenText>
        <RadzenDataGrid Data="@_singleItem.Activity.Activities" TItem="ActivityLog" Density="Density.Compact" AllowPaging="false" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="ActivityLog" Property="Name" Title="Name" />
                <RadzenDataGridColumn TItem="ActivityLog" Property="Calories" Title="Calories" />
                <RadzenDataGridColumn TItem="ActivityLog" Title="Duration">
                    <Template Context="activity">@FormatDuration(activity.Duration)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActivityLog" Title="Steps">
                    <Template Context="activity">@activity.Steps.ToString("N0")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActivityLog" Title="Distance">
                    <Template Context="activity">@(activity.Distance.HasValue ? $"{activity.Distance:F2} km" : "--")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActivityLog" Property="StartTime" Title="Start Time" />
            </Columns>
        </RadzenDataGrid>
    }

    @if (_singleItem.Activity.Summary.Distances.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Distances</RadzenText>
        <RadzenDataGrid Data="@_singleItem.Activity.Summary.Distances" TItem="DistanceData" Density="Density.Compact" AllowPaging="false" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="DistanceData" Property="Activity" Title="Activity" />
                <RadzenDataGridColumn TItem="DistanceData" Title="Distance (km)">
                    <Template Context="d">@d.Distance.ToString("F2")</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
}

@if (!_isLoading && _rangeItems is not null && _mode == "range")
{
    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="Charts">
    @if (_rangeItems.Items.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Steps Over Time</RadzenText>
        <RadzenChart Style="height: 300px;" class="rz-mb-4">
            <RadzenLineSeries Data="@GetRangeStepsData()" CategoryProperty="Date" ValueProperty="Value"
                Title="Steps" Smooth="true" />
            <RadzenCategoryAxis Padding="20" />
            <RadzenValueAxis>
                <RadzenGridLines Visible="true" />
            </RadzenValueAxis>
        </RadzenChart>

        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Resting Heart Rate Over Time</RadzenText>
        <RadzenChart Style="height: 300px;" class="rz-mb-4">
            <RadzenLineSeries Data="@GetRangeRestingHrData()" CategoryProperty="Date" ValueProperty="Value"
                Title="Resting HR (bpm)" Smooth="true" />
            <RadzenCategoryAxis Padding="20" />
            <RadzenValueAxis>
                <RadzenGridLines Visible="true" />
            </RadzenValueAxis>
        </RadzenChart>

        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Active Minutes Breakdown Over Time</RadzenText>
        <RadzenChart Style="height: 300px;" class="rz-mb-4">
            <RadzenAreaSeries Data="@GetRangeSedentaryData()" CategoryProperty="Date" ValueProperty="Value"
                Title="Sedentary" Smooth="true" />
            <RadzenAreaSeries Data="@GetRangeLightlyActiveData()" CategoryProperty="Date" ValueProperty="Value"
                Title="Lightly Active" Smooth="true" />
            <RadzenAreaSeries Data="@GetRangeFairlyActiveData()" CategoryProperty="Date" ValueProperty="Value"
                Title="Fairly Active" Smooth="true" />
            <RadzenAreaSeries Data="@GetRangeVeryActiveData()" CategoryProperty="Date" ValueProperty="Value"
                Title="Very Active" Smooth="true" />
            <RadzenCategoryAxis Padding="20" />
            <RadzenValueAxis>
                <RadzenGridLines Visible="true" />
            </RadzenValueAxis>
        </RadzenChart>
    }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Table">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Activity Records</RadzenText>
    <RadzenDataGrid Data="@_rangeItems.Items" TItem="ActivityItem" Density="Density.Compact"
                    AllowPaging="true" PageSize="10" Count="@_rangeItems.TotalCount" LoadData="@OnLoadData" class="rz-mb-4">
        <Columns>
            <RadzenDataGridColumn TItem="ActivityItem" Property="Date" Title="Date" />
            <RadzenDataGridColumn TItem="ActivityItem" Title="Steps">
                <Template Context="item">@item.Activity.Summary.Steps.ToString("N0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ActivityItem" Title="Calories">
                <Template Context="item">@item.Activity.Summary.CaloriesOut.ToString("N0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ActivityItem" Title="Active Min">
                <Template Context="item">@((item.Activity.Summary.FairlyActiveMinutes + item.Activity.Summary.VeryActiveMinutes).ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ActivityItem" Title="Floors">
                <Template Context="item">@item.Activity.Summary.Floors</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ActivityItem" Title="Resting HR">
                <Template Context="item">@(item.Activity.Summary.RestingHeartRate > 0 ? item.Activity.Summary.RestingHeartRate.ToString() : "--")</Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
}

@if (!_isLoading && _singleItem is null && _mode == "date" && _errorMessage is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">No activity data found for @_selectedDate.</RadzenAlert>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _mode = "date";
    private string _selectedDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private string _startDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-8)).ToString("yyyy-MM-dd");
    private string _endDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private int _currentPage = 1;

    private ActivityItem? _singleItem;
    private PaginatedResponse<ActivityItem>? _rangeItems;

    protected override async Task OnInitializedAsync()
    {
        await LoadByDate(_selectedDate);
    }

    private async Task LoadByDate(string date)
    {
        _mode = "date";
        _selectedDate = date;
        _isLoading = true;
        _errorMessage = null;
        _singleItem = null;

        try
        {
            _singleItem = await ApiService.GetActivityByDateAsync(date);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load activity data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadByRange((string StartDate, string EndDate) range)
    {
        _mode = "range";
        _startDate = range.StartDate;
        _endDate = range.EndDate;
        _currentPage = 1;
        await LoadRangePage();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadRangePage();
    }

    private async Task LoadRangePage()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _rangeItems = await ApiService.GetActivitiesByDateRangeAsync(_startDate, _endDate, _currentPage);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load activity data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnLoadData(LoadDataArgs args)
    {
        _currentPage = (int)((args.Skip ?? 0) / 10) + 1;
        await LoadRangePage();
    }

    private static string GetGoalProgress(int actual, int goal)
    {
        if (goal == 0) return "";
        var pct = (double)actual / goal * 100;
        return $"{pct:F0}% of {goal:N0} goal";
    }

    private static double GetGoalPercent(int actual, int goal)
    {
        if (goal == 0) return 0;
        return Math.Min((double)actual / goal * 100, 100);
    }

    private static string FormatDuration(long milliseconds)
    {
        var ts = TimeSpan.FromMilliseconds(milliseconds);
        return ts.TotalHours >= 1 ? $"{(int)ts.TotalHours}h {ts.Minutes}m" : $"{ts.Minutes}m";
    }

    private record ActiveMinuteItem(string Category, int Minutes);

    private List<ActiveMinuteItem> GetActiveMinutesBreakdown()
    {
        var s = _singleItem!.Activity.Summary;
        return
        [
            new("Sedentary", s.SedentaryMinutes),
            new("Lightly Active", s.LightlyActiveMinutes),
            new("Fairly Active", s.FairlyActiveMinutes),
            new("Very Active", s.VeryActiveMinutes)
        ];
    }

    private record ChartDataPoint(string Date, double Value);

    private List<ChartDataPoint> GetRangeStepsData() =>
        _rangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.Steps)).ToList();

    private List<ChartDataPoint> GetRangeRestingHrData() =>
        _rangeItems!.Items
            .Where(a => a.Activity.Summary.RestingHeartRate > 0)
            .Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.RestingHeartRate)).ToList();

    private List<ChartDataPoint> GetRangeSedentaryData() =>
        _rangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.SedentaryMinutes)).ToList();

    private List<ChartDataPoint> GetRangeLightlyActiveData() =>
        _rangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.LightlyActiveMinutes)).ToList();

    private List<ChartDataPoint> GetRangeFairlyActiveData() =>
        _rangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.FairlyActiveMinutes)).ToList();

    private List<ChartDataPoint> GetRangeVeryActiveData() =>
        _rangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.VeryActiveMinutes)).ToList();
}
