@page "/activity"
@rendermode InteractiveServer
@inherits DataPageBase<ActivityItem, ActivityItem>

<PageTitle>Biotrackr - Activity</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Activity</RadzenText>

<DatePicker SelectedDate="@SelectedDate" StartDate="@StartDate" EndDate="@EndDate" Mode="@Mode"
            OnSingleDateSelected="LoadByDate" OnDateRangeSelected="LoadByRange" />

<LoadingSpinner IsLoading="@IsLoading" Message="Loading activity data..." />
<ErrorDisplay Message="@ErrorMessage" />

@if (!IsLoading && SingleItem is not null && Mode == "date")
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Steps" Value="@(SingleItem.Activity.Summary.Steps.ToString("N0"))" 
                         Subtitle="@GetGoalProgress(SingleItem.Activity.Summary.Steps, SingleItem.Activity.Goals.Steps)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Calories Burned" Value="@(SingleItem.Activity.Summary.CaloriesOut.ToString("N0"))"
                         Subtitle="@GetGoalProgress(SingleItem.Activity.Summary.CaloriesOut, SingleItem.Activity.Goals.CaloriesOut)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Active Minutes" Value="@((SingleItem.Activity.Summary.FairlyActiveMinutes + SingleItem.Activity.Summary.VeryActiveMinutes).ToString("N0"))"
                         Subtitle="@GetGoalProgress(SingleItem.Activity.Summary.FairlyActiveMinutes + SingleItem.Activity.Summary.VeryActiveMinutes, SingleItem.Activity.Goals.ActiveMinutes)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Floors" Value="@(SingleItem.Activity.Summary.Floors.ToString("N0"))"
                         Subtitle="@GetGoalProgress(SingleItem.Activity.Summary.Floors, SingleItem.Activity.Goals.Floors)" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Goal Progress</RadzenText>
    <RadzenRow Gap="1rem" class="rz-mb-4" AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6" SizeSM="6">
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Subtitle2">Steps: @SingleItem.Activity.Summary.Steps.ToString("N0") / @SingleItem.Activity.Goals.Steps.ToString("N0")</RadzenText>
                <RadzenProgressBar Value="@GetGoalPercent(SingleItem.Activity.Summary.Steps, SingleItem.Activity.Goals.Steps)" ShowValue="true" Mode="ProgressBarMode.Determinate" Style="height: 20px;" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeSM="6">
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Subtitle2">Calories Burned: @SingleItem.Activity.Summary.CaloriesOut.ToString("N0") / @SingleItem.Activity.Goals.CaloriesOut.ToString("N0")</RadzenText>
                <RadzenProgressBar Value="@GetGoalPercent(SingleItem.Activity.Summary.CaloriesOut, SingleItem.Activity.Goals.CaloriesOut)" ShowValue="true" Mode="ProgressBarMode.Determinate" Style="height: 20px;" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    @if (SingleItem.Activity.Summary.HeartRateZones.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Heart Rate Zones Chart</RadzenText>
        <figure role="group" aria-label="Heart rate zones chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenBarSeries Data="@SingleItem.Activity.Summary.HeartRateZones" CategoryProperty="Name"
                    ValueProperty="Minutes" Title="Minutes" />
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Bar chart showing minutes spent in each heart rate zone.</figcaption>
        </figure>
    }

    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Active Minutes Breakdown</RadzenText>
    <figure role="group" aria-label="Active minutes breakdown chart">
        <RadzenChart class="bt-chart rz-mb-4">
            <RadzenBarSeries Data="@GetActiveMinutesBreakdown()" CategoryProperty="Category" ValueProperty="Minutes" Title="Minutes" />
            <RadzenCategoryAxis Padding="20" />
            <RadzenValueAxis>
                <RadzenGridLines Visible="true" />
            </RadzenValueAxis>
        </RadzenChart>
        <figcaption class="sr-only">Bar chart showing sedentary, lightly active, fairly active, and very active minutes.</figcaption>
    </figure>

    @if (SingleItem.Activity.Summary.HeartRateZones.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Heart Rate Zones</RadzenText>
        <RadzenDataGrid Data="@SingleItem.Activity.Summary.HeartRateZones" TItem="HeartRateZone" Density="Density.Compact" AllowPaging="false" Responsive="true" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="HeartRateZone" Property="Name" Title="Zone" />
                <RadzenDataGridColumn TItem="HeartRateZone" Property="Minutes" Title="Minutes" />
                <RadzenDataGridColumn TItem="HeartRateZone" Title="Calories">
                    <Template Context="zone">@zone.CaloriesOut.ToString("F1")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="HeartRateZone" Title="Range (bpm)">
                    <Template Context="zone">@zone.Min - @zone.Max</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }

    @if (SingleItem.Activity.Activities.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Activities</RadzenText>
        <RadzenDataGrid Data="@SingleItem.Activity.Activities" TItem="ActivityLog" Density="Density.Compact" AllowPaging="false" Responsive="true" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="ActivityLog" Property="Name" Title="Name" />
                <RadzenDataGridColumn TItem="ActivityLog" Property="Calories" Title="Calories" />
                <RadzenDataGridColumn TItem="ActivityLog" Title="Duration">
                    <Template Context="activity">@FormatDuration(activity.Duration)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActivityLog" Title="Steps">
                    <Template Context="activity">@activity.Steps.ToString("N0")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActivityLog" Title="Distance">
                    <Template Context="activity">@(activity.Distance.HasValue ? $"{activity.Distance:F2} km" : "--")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActivityLog" Property="StartTime" Title="Start Time" />
            </Columns>
        </RadzenDataGrid>
    }

    @if (SingleItem.Activity.Summary.Distances.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Distances</RadzenText>
        <RadzenDataGrid Data="@SingleItem.Activity.Summary.Distances" TItem="DistanceData" Density="Density.Compact" AllowPaging="false" Responsive="true" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="DistanceData" Property="Activity" Title="Activity" />
                <RadzenDataGridColumn TItem="DistanceData" Title="Distance (km)">
                    <Template Context="d">@d.Distance.ToString("F2")</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
}

@if (!IsLoading && RangeItems is not null && Mode == "range")
{
    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="Charts">
    @if (RangeItems.Items.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Steps Over Time</RadzenText>
        <figure role="group" aria-label="Steps over time chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenLineSeries Data="@GetRangeStepsData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Steps" Smooth="true" />
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Line chart showing daily step count trend. See the Table tab for exact values.</figcaption>
        </figure>

        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Resting Heart Rate Over Time</RadzenText>
        <figure role="group" aria-label="Resting heart rate over time chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenLineSeries Data="@GetRangeRestingHrData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Resting HR (bpm)" Smooth="true" />
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Line chart showing daily resting heart rate trend. See the Table tab for exact values.</figcaption>
        </figure>

        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Active Minutes Breakdown Over Time</RadzenText>
        <figure role="group" aria-label="Active minutes breakdown over time chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenAreaSeries Data="@GetRangeSedentaryData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Sedentary" Smooth="true" />
                <RadzenAreaSeries Data="@GetRangeLightlyActiveData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Lightly Active" Smooth="true" />
                <RadzenAreaSeries Data="@GetRangeFairlyActiveData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Fairly Active" Smooth="true" />
                <RadzenAreaSeries Data="@GetRangeVeryActiveData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Very Active" Smooth="true" />
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Stacked area chart showing sedentary, lightly active, fairly active, and very active minutes over time. See the Table tab for exact values.</figcaption>
        </figure>
    }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Table">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Activity Records</RadzenText>
    <RadzenDataGrid Data="@RangeItems.Items" TItem="ActivityItem" Density="Density.Compact"
                    AllowPaging="true" PageSize="10" Count="@RangeItems.TotalCount" LoadData="@OnLoadData" Responsive="true" class="rz-mb-4">
        <Columns>
            <RadzenDataGridColumn TItem="ActivityItem" Property="Date" Title="Date" />
            <RadzenDataGridColumn TItem="ActivityItem" Title="Steps">
                <Template Context="item">@item.Activity.Summary.Steps.ToString("N0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ActivityItem" Title="Calories">
                <Template Context="item">@item.Activity.Summary.CaloriesOut.ToString("N0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ActivityItem" Title="Active Min">
                <Template Context="item">@((item.Activity.Summary.FairlyActiveMinutes + item.Activity.Summary.VeryActiveMinutes).ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ActivityItem" Title="Floors">
                <Template Context="item">@item.Activity.Summary.Floors</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ActivityItem" Title="Resting HR">
                <Template Context="item">@(item.Activity.Summary.RestingHeartRate > 0 ? item.Activity.Summary.RestingHeartRate.ToString() : "--")</Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
}

@if (!IsLoading && SingleItem is null && Mode == "date" && ErrorMessage is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">No activity data found for @SelectedDate.</RadzenAlert>
}

@code {
    protected override string DataName => "activity";

    protected override Task<ActivityItem?> FetchSingleAsync(string date)
        => ApiService.GetActivityByDateAsync(date);

    protected override Task<PaginatedResponse<ActivityItem>> FetchRangeAsync(string start, string end, int page)
        => ApiService.GetActivitiesByDateRangeAsync(start, end, page);

    private static string GetGoalProgress(int actual, int goal)
    {
        if (goal == 0) return "";
        var pct = (double)actual / goal * 100;
        return $"{pct:F0}% of {goal:N0} goal";
    }

    private static double GetGoalPercent(int actual, int goal)
    {
        if (goal == 0) return 0;
        return Math.Min((double)actual / goal * 100, 100);
    }

    private static string FormatDuration(long milliseconds)
    {
        var ts = TimeSpan.FromMilliseconds(milliseconds);
        return ts.TotalHours >= 1 ? $"{(int)ts.TotalHours}h {ts.Minutes}m" : $"{ts.Minutes}m";
    }

    private record ActiveMinuteItem(string Category, int Minutes);

    private List<ActiveMinuteItem> GetActiveMinutesBreakdown()
    {
        var s = SingleItem!.Activity.Summary;
        return
        [
            new("Sedentary", s.SedentaryMinutes),
            new("Lightly Active", s.LightlyActiveMinutes),
            new("Fairly Active", s.FairlyActiveMinutes),
            new("Very Active", s.VeryActiveMinutes)
        ];
    }

    private record ChartDataPoint(string Date, double Value);

    private List<ChartDataPoint> GetRangeStepsData() =>
        RangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.Steps)).ToList();

    private List<ChartDataPoint> GetRangeRestingHrData() =>
        RangeItems!.Items
            .Where(a => a.Activity.Summary.RestingHeartRate > 0)
            .Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.RestingHeartRate)).ToList();

    private List<ChartDataPoint> GetRangeSedentaryData() =>
        RangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.SedentaryMinutes)).ToList();

    private List<ChartDataPoint> GetRangeLightlyActiveData() =>
        RangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.LightlyActiveMinutes)).ToList();

    private List<ChartDataPoint> GetRangeFairlyActiveData() =>
        RangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.FairlyActiveMinutes)).ToList();

    private List<ChartDataPoint> GetRangeVeryActiveData() =>
        RangeItems!.Items.Select(a => new ChartDataPoint(a.Date, a.Activity.Summary.VeryActiveMinutes)).ToList();
}
