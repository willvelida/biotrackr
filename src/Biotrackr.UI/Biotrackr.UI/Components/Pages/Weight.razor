@page "/weight"
@rendermode InteractiveServer
@inject IBiotrackrApiService ApiService

<PageTitle>Biotrackr - Weight</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Weight</RadzenText>

<DatePicker SelectedDate="@_selectedDate" StartDate="@_startDate" EndDate="@_endDate" Mode="@_mode"
            OnSingleDateSelected="LoadByDate" OnDateRangeSelected="LoadByRange" />

<LoadingSpinner IsLoading="@_isLoading" Message="Loading weight data..." />
<ErrorDisplay Message="@_errorMessage" />

@if (!_isLoading && _singleItem is not null && _mode == "date")
{
    @if (_singleItem.Weight.Weight > 0)
    {
        <RadzenRow Gap="1rem" class="rz-mb-4">
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <SummaryCard Title="Weight" Value="@($"{_singleItem.Weight.Weight:F1} kg")" />
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <SummaryCard Title="BMI" Value="@($"{_singleItem.Weight.Bmi:F1}")" Subtitle="@GetBmiCategory(_singleItem.Weight.Bmi)" />
            </RadzenColumn>
            @if (_singleItem.Weight.Fat > 0)
            {
                <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                    <SummaryCard Title="Body Fat" Value="@($"{_singleItem.Weight.Fat:F1}%")" />
                </RadzenColumn>
            }
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <SummaryCard Title="Recorded" Value="@_singleItem.Weight.Time" Subtitle="@_singleItem.Weight.Source" />
            </RadzenColumn>
        </RadzenRow>
    }
    else
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">No weight entries for @_selectedDate.</RadzenAlert>
    }
}

@if (!_isLoading && _rangeItems is not null && _mode == "range")
{
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Weight Records</RadzenText>
    <RadzenDataGrid Data="@_rangeItems.Items" TItem="WeightItem" Density="Density.Compact"
                    AllowPaging="true" PageSize="10" Count="@_rangeItems.TotalCount" LoadData="@OnLoadData" class="rz-mb-4">
        <Columns>
            <RadzenDataGridColumn TItem="WeightItem" Property="Date" Title="Date" />
            <RadzenDataGridColumn TItem="WeightItem" Title="Weight (kg)">
                <Template Context="item">@item.Weight.Weight.ToString("F1")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="WeightItem" Title="BMI">
                <Template Context="item">@item.Weight.Bmi.ToString("F1")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="WeightItem" Title="Body Fat %">
                <Template Context="item">@(item.Weight.Fat > 0 ? item.Weight.Fat.ToString("F1") : "--")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="WeightItem" Title="Time">
                <Template Context="item">@item.Weight.Time</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="WeightItem" Title="Source">
                <Template Context="item">@item.Weight.Source</Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@if (!_isLoading && _singleItem is null && _mode == "date" && _errorMessage is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">No weight data found for @_selectedDate.</RadzenAlert>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _mode = "date";
    private string _selectedDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private string _startDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-8)).ToString("yyyy-MM-dd");
    private string _endDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private int _currentPage = 1;

    private WeightItem? _singleItem;
    private PaginatedResponse<WeightItem>? _rangeItems;

    protected override async Task OnInitializedAsync()
    {
        await LoadByDate(_selectedDate);
    }

    private async Task LoadByDate(string date)
    {
        _mode = "date";
        _selectedDate = date;
        _isLoading = true;
        _errorMessage = null;
        _singleItem = null;

        try
        {
            _singleItem = await ApiService.GetWeightByDateAsync(date);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load weight data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadByRange((string StartDate, string EndDate) range)
    {
        _mode = "range";
        _startDate = range.StartDate;
        _endDate = range.EndDate;
        _currentPage = 1;
        await LoadRangePage();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadRangePage();
    }

    private async Task LoadRangePage()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _rangeItems = await ApiService.GetWeightByDateRangeAsync(_startDate, _endDate, _currentPage);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load weight data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnLoadData(LoadDataArgs args)
    {
        _currentPage = (int)((args.Skip ?? 0) / 10) + 1;
        await LoadRangePage();
    }

    private static string GetBmiCategory(double bmi)
    {
        if (bmi < 18.5) return "Underweight";
        if (bmi < 25.0) return "Normal";
        if (bmi < 30.0) return "Overweight";
        return "Obese";
    }
}
