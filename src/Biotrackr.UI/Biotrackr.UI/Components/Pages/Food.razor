@page "/food"
@rendermode InteractiveServer
@inherits DataPageBase<FoodItem, FoodItem>

<PageTitle>Biotrackr - Food</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Food</RadzenText>

<DatePicker SelectedDate="@SelectedDate" StartDate="@StartDate" EndDate="@EndDate" Mode="@Mode"
            OnSingleDateSelected="LoadByDate" OnDateRangeSelected="LoadByRange" />

<LoadingSpinner IsLoading="@IsLoading" Message="Loading food data..." />
<ErrorDisplay Message="@ErrorMessage" />

@if (!IsLoading && SingleItem is not null && Mode == "date")
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Calories" Value="@(((int)(SingleItem.Food?.Summary?.Calories ?? 0)).ToString("N0"))" Subtitle="@GetCalorieGoalText()" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Protein" Value="@($"{SingleItem.Food?.Summary?.Protein ?? 0:F1}g")" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Carbs" Value="@($"{SingleItem.Food?.Summary?.Carbs ?? 0:F1}g")" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Fat" Value="@($"{SingleItem.Food?.Summary?.Fat ?? 0:F1}g")" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Fiber" Value="@($"{SingleItem.Food?.Summary?.Fiber ?? 0:F1}g")" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Water" Value="@($"{SingleItem.Food?.Summary?.Water ?? 0:F0} ml")" />
        </RadzenColumn>
    </RadzenRow>

    @if (SingleItem.Food?.Summary is not null)
    {
        <RadzenRow Gap="1rem" class="rz-mb-4" AlignItems="AlignItems.Center">
            <RadzenColumn Size="12" SizeMD="6" SizeSM="12">
                <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Macronutrient Split</RadzenText>
                <figure role="group" aria-label="Macronutrient split chart">
                    <RadzenChart class="bt-chart">
                        <RadzenDonutSeries Data="@GetMacroData()" CategoryProperty="Nutrient"
                            ValueProperty="Grams" Title="Macronutrients (g)" />
                    </RadzenChart>
                    <figcaption class="sr-only">Donut chart showing the proportion of protein, carbs, and fat in grams.</figcaption>
                </figure>
            </RadzenColumn>
            @if (SingleItem.Food.Goals.Calories > 0)
            {
                <RadzenColumn Size="12" SizeMD="6" SizeSM="12">
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Calories vs Goal</RadzenText>
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Subtitle2">@($"{SingleItem.Food.Summary.Calories:N0} / {SingleItem.Food.Goals.Calories:N0}")</RadzenText>
                        <RadzenProgressBar Value="@(Math.Min(SingleItem.Food.Summary.Calories / SingleItem.Food.Goals.Calories * 100, 100))" ShowValue="true" Mode="ProgressBarMode.Determinate" Style="height: 20px;" />
                    </RadzenStack>
                </RadzenColumn>
            }
        </RadzenRow>
    }

    @if (SingleItem.Food?.Foods?.Any() == true)
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Food Log</RadzenText>
        <RadzenDataGrid Data="@SingleItem.Food.Foods" TItem="FoodEntry" Density="Density.Compact" AllowPaging="false" Responsive="true" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Food">
                    <Template Context="entry">@entry.LoggedFood?.Name</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Brand">
                    <Template Context="entry">@(string.IsNullOrEmpty(entry.LoggedFood?.Brand) ? "--" : entry.LoggedFood.Brand)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Calories">
                    <Template Context="entry">@(entry.NutritionalValues?.Calories.ToString("F0") ?? "--")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Protein">
                    <Template Context="entry">@(entry.NutritionalValues?.Protein.ToString("F1") ?? "--")g</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Carbs">
                    <Template Context="entry">@(entry.NutritionalValues?.Carbs.ToString("F1") ?? "--")g</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Fat">
                    <Template Context="entry">@(entry.NutritionalValues?.Fat.ToString("F1") ?? "--")g</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Amount">
                    <Template Context="entry">@(entry.LoggedFood?.Amount) @(entry.LoggedFood?.Unit?.Name)</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
}

@if (!IsLoading && RangeItems is not null && Mode == "range")
{
    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="Charts">
    @if (RangeItems.Items.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Calories Over Time</RadzenText>
        <figure role="group" aria-label="Calories over time chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenLineSeries Data="@GetRangeCaloriesData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Calories" Smooth="true" />
                @if (GetRangeGoalLineData().Any())
                {
                    <RadzenLineSeries Data="@GetRangeGoalLineData()" CategoryProperty="Date" ValueProperty="Value"
                        Title="Goal" LineType="LineType.Dashed" />
                }
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Line chart showing daily calorie intake trend with goal line. See the Table tab for exact values.</figcaption>
        </figure>

        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Macronutrients Over Time</RadzenText>
        <figure role="group" aria-label="Macronutrients over time chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenAreaSeries Data="@GetRangeCarbsData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Carbs" Smooth="true" />
                <RadzenAreaSeries Data="@GetRangeFatData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Fat" Smooth="true" />
                <RadzenAreaSeries Data="@GetRangeProteinData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Protein" Smooth="true" />
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Stacked area chart showing carbs, fat, and protein intake over time. See the Table tab for exact values.</figcaption>
        </figure>
    }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Table">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Food Records</RadzenText>
    <RadzenDataGrid Data="@RangeItems.Items" TItem="FoodItem" Density="Density.Compact"
                    AllowPaging="true" PageSize="10" Count="@RangeItems.TotalCount" LoadData="@OnLoadData" Responsive="true" class="rz-mb-4">
        <Columns>
            <RadzenDataGridColumn TItem="FoodItem" Property="Date" Title="Date" />
            <RadzenDataGridColumn TItem="FoodItem" Title="Calories">
                <Template Context="item">@(((int)(item.Food?.Summary?.Calories ?? 0)).ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Protein">
                <Template Context="item">@(item.Food?.Summary?.Protein.ToString("F1") ?? "0.0")g</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Carbs">
                <Template Context="item">@(item.Food?.Summary?.Carbs.ToString("F1") ?? "0.0")g</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Fat">
                <Template Context="item">@(item.Food?.Summary?.Fat.ToString("F1") ?? "0.0")g</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Fiber">
                <Template Context="item">@(item.Food?.Summary?.Fiber.ToString("F1") ?? "0.0")g</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Items">
                <Template Context="item">@(item.Food?.Foods?.Count ?? 0)</Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
}

@if (!IsLoading && SingleItem is null && Mode == "date" && ErrorMessage is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">No food data found for @SelectedDate.</RadzenAlert>
}

@code {
    protected override string DataName => "food";

    protected override Task<FoodItem?> FetchSingleAsync(string date)
        => ApiService.GetFoodLogByDateAsync(date);

    protected override Task<PaginatedResponse<FoodItem>> FetchRangeAsync(string start, string end, int page)
        => ApiService.GetFoodLogsByDateRangeAsync(start, end, page);

    private string GetCalorieGoalText()
    {
        if (SingleItem?.Food?.Goals is null || SingleItem.Food.Goals.Calories == 0) return "";
        var summary = SingleItem.Food.Summary;
        if (summary is null) return "";
        var pct = summary.Calories / SingleItem.Food.Goals.Calories * 100;
        return $"{pct:F0}% of {SingleItem.Food.Goals.Calories:N0} goal";
    }

    private record MacroDataPoint(string Nutrient, double Grams);

    private List<MacroDataPoint> GetMacroData()
    {
        var s = SingleItem!.Food!.Summary!;
        return
        [
            new("Protein", Math.Round(s.Protein, 1)),
            new("Carbs", Math.Round(s.Carbs, 1)),
            new("Fat", Math.Round(s.Fat, 1))
        ];
    }

    private record ChartDataPoint(string Date, double Value);

    private List<ChartDataPoint> GetRangeCaloriesData() =>
        RangeItems!.Items.Select(f => new ChartDataPoint(f.Date, f.Food?.Summary?.Calories ?? 0)).ToList();

    private List<ChartDataPoint> GetRangeGoalLineData()
    {
        var goal = RangeItems!.Items.FirstOrDefault()?.Food?.Goals?.Calories ?? 0;
        if (goal == 0) return [];
        return RangeItems.Items.Select(f => new ChartDataPoint(f.Date, goal)).ToList();
    }

    private List<ChartDataPoint> GetRangeCarbsData() =>
        RangeItems!.Items.Select(f => new ChartDataPoint(f.Date, f.Food?.Summary?.Carbs ?? 0)).ToList();

    private List<ChartDataPoint> GetRangeFatData() =>
        RangeItems!.Items.Select(f => new ChartDataPoint(f.Date, f.Food?.Summary?.Fat ?? 0)).ToList();

    private List<ChartDataPoint> GetRangeProteinData() =>
        RangeItems!.Items.Select(f => new ChartDataPoint(f.Date, f.Food?.Summary?.Protein ?? 0)).ToList();
}
