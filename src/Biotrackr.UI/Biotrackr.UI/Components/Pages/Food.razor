@page "/food"
@rendermode InteractiveServer
@inject IBiotrackrApiService ApiService

<PageTitle>Biotrackr - Food</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Food</RadzenText>

<DatePicker SelectedDate="@_selectedDate" StartDate="@_startDate" EndDate="@_endDate" Mode="@_mode"
            OnSingleDateSelected="LoadByDate" OnDateRangeSelected="LoadByRange" />

<LoadingSpinner IsLoading="@_isLoading" Message="Loading food data..." />
<ErrorDisplay Message="@_errorMessage" />

@if (!_isLoading && _singleItem is not null && _mode == "date")
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Calories" Value="@(((int)(_singleItem.Food?.Summary?.Calories ?? 0)).ToString("N0"))" Subtitle="@GetCalorieGoalText()" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Protein" Value="@($"{_singleItem.Food?.Summary?.Protein ?? 0:F1}g")" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Carbs" Value="@($"{_singleItem.Food?.Summary?.Carbs ?? 0:F1}g")" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Fat" Value="@($"{_singleItem.Food?.Summary?.Fat ?? 0:F1}g")" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Fiber" Value="@($"{_singleItem.Food?.Summary?.Fiber ?? 0:F1}g")" />
        </RadzenColumn>
        <RadzenColumn SizeMD="2" SizeSM="4" Size="6">
            <SummaryCard Title="Water" Value="@($"{_singleItem.Food?.Summary?.Water ?? 0:F0} ml")" />
        </RadzenColumn>
    </RadzenRow>

    @if (_singleItem.Food?.Foods?.Any() == true)
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Food Log</RadzenText>
        <RadzenDataGrid Data="@_singleItem.Food.Foods" TItem="FoodEntry" Density="Density.Compact" AllowPaging="false" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Food">
                    <Template Context="entry">@entry.LoggedFood?.Name</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Brand">
                    <Template Context="entry">@(string.IsNullOrEmpty(entry.LoggedFood?.Brand) ? "--" : entry.LoggedFood.Brand)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Calories">
                    <Template Context="entry">@(entry.NutritionalValues?.Calories.ToString("F0") ?? "--")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Protein">
                    <Template Context="entry">@(entry.NutritionalValues?.Protein.ToString("F1") ?? "--")g</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Carbs">
                    <Template Context="entry">@(entry.NutritionalValues?.Carbs.ToString("F1") ?? "--")g</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Fat">
                    <Template Context="entry">@(entry.NutritionalValues?.Fat.ToString("F1") ?? "--")g</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FoodEntry" Title="Amount">
                    <Template Context="entry">@(entry.LoggedFood?.Amount) @(entry.LoggedFood?.Unit?.Name)</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
}

@if (!_isLoading && _rangeItems is not null && _mode == "range")
{
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Food Records</RadzenText>
    <RadzenDataGrid Data="@_rangeItems.Items" TItem="FoodItem" Density="Density.Compact"
                    AllowPaging="true" PageSize="10" Count="@_rangeItems.TotalCount" LoadData="@OnLoadData" class="rz-mb-4">
        <Columns>
            <RadzenDataGridColumn TItem="FoodItem" Property="Date" Title="Date" />
            <RadzenDataGridColumn TItem="FoodItem" Title="Calories">
                <Template Context="item">@(((int)(item.Food?.Summary?.Calories ?? 0)).ToString("N0"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Protein">
                <Template Context="item">@(item.Food?.Summary?.Protein.ToString("F1") ?? "0.0")g</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Carbs">
                <Template Context="item">@(item.Food?.Summary?.Carbs.ToString("F1") ?? "0.0")g</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Fat">
                <Template Context="item">@(item.Food?.Summary?.Fat.ToString("F1") ?? "0.0")g</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Fiber">
                <Template Context="item">@(item.Food?.Summary?.Fiber.ToString("F1") ?? "0.0")g</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FoodItem" Title="Items">
                <Template Context="item">@(item.Food?.Foods?.Count ?? 0)</Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@if (!_isLoading && _singleItem is null && _mode == "date" && _errorMessage is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">No food data found for @_selectedDate.</RadzenAlert>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _mode = "date";
    private string _selectedDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private string _startDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-8)).ToString("yyyy-MM-dd");
    private string _endDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private int _currentPage = 1;

    private FoodItem? _singleItem;
    private PaginatedResponse<FoodItem>? _rangeItems;

    protected override async Task OnInitializedAsync()
    {
        await LoadByDate(_selectedDate);
    }

    private async Task LoadByDate(string date)
    {
        _mode = "date";
        _selectedDate = date;
        _isLoading = true;
        _errorMessage = null;
        _singleItem = null;

        try
        {
            _singleItem = await ApiService.GetFoodLogByDateAsync(date);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load food data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadByRange((string StartDate, string EndDate) range)
    {
        _mode = "range";
        _startDate = range.StartDate;
        _endDate = range.EndDate;
        _currentPage = 1;
        await LoadRangePage();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadRangePage();
    }

    private async Task LoadRangePage()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _rangeItems = await ApiService.GetFoodLogsByDateRangeAsync(_startDate, _endDate, _currentPage);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load food data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnLoadData(LoadDataArgs args)
    {
        _currentPage = (int)((args.Skip ?? 0) / 10) + 1;
        await LoadRangePage();
    }

    private string GetCalorieGoalText()
    {
        if (_singleItem?.Food?.Goals is null || _singleItem.Food.Goals.Calories == 0) return "";
        var summary = _singleItem.Food.Summary;
        if (summary is null) return "";
        var pct = summary.Calories / _singleItem.Food.Goals.Calories * 100;
        return $"{pct:F0}% of {_singleItem.Food.Goals.Calories:N0} goal";
    }
}
