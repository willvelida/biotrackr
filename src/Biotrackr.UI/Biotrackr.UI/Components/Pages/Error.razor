@page "/Error"

<PageTitle>Biotrackr - Error</PageTitle>

<div class="text-center py-5">
    <h1 class="text-danger mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
        </svg>
    </h1>
    <h2 class="text-danger">Something went wrong</h2>
    <p class="text-muted">An unexpected error occurred. Please try again.</p>
    @if (ShowRequestId)
    {
        <p class="small text-muted">Request ID: <code>@RequestId</code></p>
    }
    <a href="/" class="btn btn-primary mt-3">Back to Dashboard</a>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = System.Diagnostics.Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
