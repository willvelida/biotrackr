@page "/Error"
@inject NavigationManager NavigationManager

<PageTitle>Biotrackr - Error</PageTitle>

<RadzenStack AlignItems="AlignItems.Center" class="rz-py-5">
    <RadzenIcon Icon="error_outline" Style="font-size: 48px; color: var(--rz-danger);" />
    <RadzenText TextStyle="TextStyle.H5" Style="color: var(--rz-danger);">Something went wrong</RadzenText>
    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">
        An unexpected error occurred. Please try again.
    </RadzenText>
    @if (ShowRequestId)
    {
        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">Request ID: @RequestId</RadzenText>
    }
    <RadzenButton Text="Back to Dashboard" ButtonStyle="ButtonStyle.Primary"
                  Click="@(() => NavigationManager.NavigateTo("/"))" class="rz-mt-3" />
</RadzenStack>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = System.Diagnostics.Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
