@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IBiotrackrApiService ApiService

<PageTitle>Biotrackr - Dashboard</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Dashboard</RadzenText>
<RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary rz-mb-4">@DateTime.Today.AddDays(-1).ToString("dddd, MMMM d, yyyy")</RadzenText>

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-2">Activity</RadzenText>
@if (_activityLoading)
{
    <LoadingSpinner IsLoading="true" Message="Loading activity data..." />
}
else if (_activityError is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" ShowIcon="true" class="rz-mb-4">@_activityError</RadzenAlert>
}
else if (_activitySummary is not null)
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Steps" Value="@FormatNumber(_activitySummary?.Steps)" CardClass="card-activity" TrendData="@_stepsTrend" GaugeValue="@(_activitySummary?.Steps ?? 0)" GaugeMax="@(_activityGoals?.Steps ?? 0)">
                <IconContent>
                    <RadzenIcon Icon="show_chart" Style="font-size: 28px; color: #0d6efd;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Calories Burned" Value="@FormatNumber(_activitySummary?.CaloriesOut)" Subtitle="@GetCalorieGoalText()" CardClass="card-calories" TrendData="@_caloriesBurnedTrend" GaugeValue="@(_activitySummary?.CaloriesOut ?? 0)" GaugeMax="@(_activityGoals?.CaloriesOut ?? 0)">
                <IconContent>
                    <RadzenIcon Icon="local_fire_department" Style="font-size: 28px; color: #dc3545;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Active Minutes" Value="@FormatActiveMinutes()" Subtitle="@GetActiveMinutesGoalText()" CardClass="card-active" TrendData="@_activeMinutesTrend">
                <IconContent>
                    <RadzenIcon Icon="schedule" Style="font-size: 28px; color: #20c997;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Resting Heart Rate" Value="@FormatHeartRate()" Subtitle="bpm" CardClass="card-heart" TrendData="@_restingHrTrend">
                <IconContent>
                    <RadzenIcon Icon="favorite" Style="font-size: 28px; color: #e91e63;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Floors" Value="@FormatNumber(_activitySummary?.Floors)" Subtitle="@GetFloorsGoalText()" CardClass="card-floors" TrendData="@_floorsTrend">
                <IconContent>
                    <RadzenIcon Icon="stairs" Style="font-size: 28px; color: #6610f2;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
    </RadzenRow>
}
else
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true" class="rz-mb-4">No activity data available for yesterday.</RadzenAlert>
}

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-2">Sleep</RadzenText>
@if (_sleepLoading)
{
    <LoadingSpinner IsLoading="true" Message="Loading sleep data..." />
}
else if (_sleepError is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" ShowIcon="true" class="rz-mb-4">@_sleepError</RadzenAlert>
}
else if (_sleepSummary is not null)
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Sleep Duration" Value="@FormatSleepDuration()" CardClass="card-sleep" TrendData="@_sleepDurationTrend">
                <IconContent>
                    <RadzenIcon Icon="bedtime" Style="font-size: 28px; color: #6f42c1;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Sleep Efficiency" Value="@FormatSleepEfficiency()" Subtitle="%" CardClass="card-sleep" TrendData="@_sleepEfficiencyTrend">
                <IconContent>
                    <RadzenIcon Icon="bedtime" Style="font-size: 28px; color: #6f42c1;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
    </RadzenRow>
}
else
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true" class="rz-mb-4">No sleep data available for yesterday.</RadzenAlert>
}

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-2">Weight</RadzenText>
@if (_weightLoading)
{
    <LoadingSpinner IsLoading="true" Message="Loading weight data..." />
}
else if (_weightError is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" ShowIcon="true" class="rz-mb-4">@_weightError</RadzenAlert>
}
else if (_latestWeight is not null)
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Weight" Value="@FormatWeight()" CardClass="card-weight" TrendData="@_weightTrend">
                <IconContent>
                    <RadzenIcon Icon="monitor_weight" Style="font-size: 28px; color: #fd7e14;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="BMI" Value="@FormatBmi()" CardClass="card-weight" TrendData="@_bmiTrend">
                <IconContent>
                    <RadzenIcon Icon="monitor_weight" Style="font-size: 28px; color: #fd7e14;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
    </RadzenRow>
}
else
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true" class="rz-mb-4">No weight data available for yesterday.</RadzenAlert>
}

<RadzenText TextStyle="TextStyle.H5" class="rz-mb-2">Food</RadzenText>
@if (_foodLoading)
{
    <LoadingSpinner IsLoading="true" Message="Loading food data..." />
}
else if (_foodError is not null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" ShowIcon="true" class="rz-mb-4">@_foodError</RadzenAlert>
}
else if (_foodSummary is not null)
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Calories Consumed" Value="@FormatCalories(_foodSummary?.Calories)" Subtitle="@GetFoodGoalText()" CardClass="card-food" TrendData="@_caloriesConsumedTrend" GaugeValue="@(_foodSummary?.Calories ?? 0)" GaugeMax="@(_foodGoals?.Calories ?? 0)">
                <IconContent>
                    <RadzenIcon Icon="restaurant" Style="font-size: 28px; color: #198754;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Protein" Value="@FormatProtein()" CardClass="card-food" TrendData="@_proteinTrend">
                <IconContent>
                    <RadzenIcon Icon="restaurant" Style="font-size: 28px; color: #198754;" />
                </IconContent>
            </SummaryCard>
        </RadzenColumn>
    </RadzenRow>
}
else
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true" class="rz-mb-4">No food data available for yesterday.</RadzenAlert>
}

@code {
    private bool _activityLoading = true;
    private bool _sleepLoading = true;
    private bool _weightLoading = true;
    private bool _foodLoading = true;

    private readonly CancellationTokenSource _cts = new();
    private bool _disposed;

    private string? _activityError;
    private string? _sleepError;
    private string? _weightError;
    private string? _foodError;

    private ActivitySummary? _activitySummary;
    private ActivityGoals? _activityGoals;
    private FoodSummary? _foodSummary;
    private FoodGoals? _foodGoals;
    private SleepSummary? _sleepSummary;
    private WeightData? _latestWeight;

    // Trend data (7-day sparklines)
    private List<TrendDataPoint>? _stepsTrend;
    private List<TrendDataPoint>? _caloriesBurnedTrend;
    private List<TrendDataPoint>? _activeMinutesTrend;
    private List<TrendDataPoint>? _restingHrTrend;
    private List<TrendDataPoint>? _floorsTrend;
    private List<TrendDataPoint>? _sleepDurationTrend;
    private List<TrendDataPoint>? _sleepEfficiencyTrend;
    private List<TrendDataPoint>? _weightTrend;
    private List<TrendDataPoint>? _bmiTrend;
    private List<TrendDataPoint>? _caloriesConsumedTrend;
    private List<TrendDataPoint>? _proteinTrend;

    protected override async Task OnInitializedAsync()
    {
        var today = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
        var sevenDaysAgo = DateOnly.FromDateTime(DateTime.Today.AddDays(-8)).ToString("yyyy-MM-dd");

        await Task.WhenAll(
            LoadActivityAsync(today, sevenDaysAgo),
            LoadSleepAsync(today, sevenDaysAgo),
            LoadWeightAsync(today, sevenDaysAgo),
            LoadFoodAsync(today, sevenDaysAgo));
    }

    private async Task LoadActivityAsync(string today, string sevenDaysAgo)
    {
        try
        {
            var activityTask = ApiService.GetActivityByDateAsync(today);
            var trendTask = LoadActivityTrendsAsync(sevenDaysAgo, today);
            await Task.WhenAll(activityTask, trendTask);
            var activity = await activityTask;
            _activitySummary = activity?.Activity?.Summary;
            _activityGoals = activity?.Activity?.Goals;
        }
        catch (Exception) { _activityError = "Failed to load activity data. Please try again later."; }
        finally
        {
            _activityLoading = false;
            if (!_disposed) await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadSleepAsync(string today, string sevenDaysAgo)
    {
        try
        {
            var sleepTask = ApiService.GetSleepByDateAsync(today);
            var trendTask = LoadSleepTrendsAsync(sevenDaysAgo, today);
            await Task.WhenAll(sleepTask, trendTask);
            var sleep = await sleepTask;
            _sleepSummary = sleep?.Sleep?.Summary;
        }
        catch (Exception) { _sleepError = "Failed to load sleep data. Please try again later."; }
        finally
        {
            _sleepLoading = false;
            if (!_disposed) await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadWeightAsync(string today, string sevenDaysAgo)
    {
        try
        {
            var weightTask = ApiService.GetWeightByDateAsync(today);
            var trendTask = LoadWeightTrendsAsync(sevenDaysAgo, today);
            await Task.WhenAll(weightTask, trendTask);
            var weight = await weightTask;
            _latestWeight = weight?.Weight;
        }
        catch (Exception) { _weightError = "Failed to load weight data. Please try again later."; }
        finally
        {
            _weightLoading = false;
            if (!_disposed) await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadFoodAsync(string today, string sevenDaysAgo)
    {
        try
        {
            var foodTask = ApiService.GetFoodLogByDateAsync(today);
            var trendTask = LoadFoodTrendsAsync(sevenDaysAgo, today);
            await Task.WhenAll(foodTask, trendTask);
            var food = await foodTask;
            _foodSummary = food?.Food?.Summary;
            _foodGoals = food?.Food?.Goals;
        }
        catch (Exception) { _foodError = "Failed to load food data. Please try again later."; }
        finally
        {
            _foodLoading = false;
            if (!_disposed) await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadActivityTrendsAsync(string from, string to)
    {
        try
        {
            var result = await ApiService.GetActivitiesByDateRangeAsync(from, to, 1, 100);
            if (result?.Items is { Count: > 0 })
            {
                var ordered = result.Items.OrderBy(a => a.Date).ToList();
                _stepsTrend = ordered.Select(a => new TrendDataPoint { Date = a.Date, Value = a.Activity.Summary.Steps }).ToList();
                _caloriesBurnedTrend = ordered.Select(a => new TrendDataPoint { Date = a.Date, Value = a.Activity.Summary.CaloriesOut }).ToList();
                _activeMinutesTrend = ordered.Select(a => new TrendDataPoint { Date = a.Date, Value = a.Activity.Summary.FairlyActiveMinutes + a.Activity.Summary.VeryActiveMinutes }).ToList();
                _restingHrTrend = ordered.Where(a => a.Activity.Summary.RestingHeartRate > 0).Select(a => new TrendDataPoint { Date = a.Date, Value = a.Activity.Summary.RestingHeartRate }).ToList();
                _floorsTrend = ordered.Select(a => new TrendDataPoint { Date = a.Date, Value = a.Activity.Summary.Floors }).ToList();
            }
        }
        catch { /* silent degradation */ }
    }

    private async Task LoadSleepTrendsAsync(string from, string to)
    {
        try
        {
            var result = await ApiService.GetSleepByDateRangeAsync(from, to, 1, 100);
            if (result?.Items is { Count: > 0 })
            {
                var ordered = result.Items.OrderBy(s => s.Date).ToList();
                _sleepDurationTrend = ordered
                    .Select(s => new TrendDataPoint { Date = s.Date, Value = s.Sleep.Summary.TotalMinutesAsleep / 60.0 })
                    .ToList();
                _sleepEfficiencyTrend = ordered
                    .Where(s => s.Sleep.Summary.TotalTimeInBed > 0)
                    .Select(s => new TrendDataPoint { Date = s.Date, Value = Math.Round((double)s.Sleep.Summary.TotalMinutesAsleep / s.Sleep.Summary.TotalTimeInBed * 100, 0) })
                    .ToList();
            }
        }
        catch { /* silent degradation */ }
    }

    private async Task LoadWeightTrendsAsync(string from, string to)
    {
        try
        {
            var result = await ApiService.GetWeightByDateRangeAsync(from, to, 1, 100);
            if (result?.Items is { Count: > 0 })
            {
                var ordered = result.Items.OrderBy(w => w.Date).ToList();
                _weightTrend = ordered.Where(w => w.Weight.Weight > 0).Select(w => new TrendDataPoint { Date = w.Date, Value = w.Weight.Weight }).ToList();
                _bmiTrend = ordered.Where(w => w.Weight.Bmi > 0).Select(w => new TrendDataPoint { Date = w.Date, Value = w.Weight.Bmi }).ToList();
            }
        }
        catch { /* silent degradation */ }
    }

    private async Task LoadFoodTrendsAsync(string from, string to)
    {
        try
        {
            var result = await ApiService.GetFoodLogsByDateRangeAsync(from, to, 1, 100);
            if (result?.Items is { Count: > 0 })
            {
                var ordered = result.Items.OrderBy(f => f.Date).ToList();
                _caloriesConsumedTrend = ordered.Select(f => new TrendDataPoint { Date = f.Date, Value = f.Food.Summary.Calories }).ToList();
                _proteinTrend = ordered.Select(f => new TrendDataPoint { Date = f.Date, Value = f.Food.Summary.Protein }).ToList();
            }
        }
        catch { /* silent degradation */ }
    }

    private static string FormatNumber(int? value) => value.HasValue ? value.Value.ToString("N0") : "--";
    private static string FormatCalories(double? value) => value.HasValue ? ((int)value.Value).ToString("N0") : "--";

    private string FormatSleepDuration()
    {
        if (_sleepSummary is null || _sleepSummary.TotalMinutesAsleep == 0) return "--";
        var hours = _sleepSummary.TotalMinutesAsleep / 60;
        var mins = _sleepSummary.TotalMinutesAsleep % 60;
        return $"{hours}h {mins}m";
    }

    private string FormatSleepEfficiency()
    {
        if (_sleepSummary is null || _sleepSummary.TotalTimeInBed == 0) return "--";
        var efficiency = (double)_sleepSummary.TotalMinutesAsleep / _sleepSummary.TotalTimeInBed * 100;
        return $"{efficiency:F0}";
    }

    private string FormatWeight()
    {
        if (_latestWeight is null || _latestWeight.Weight == 0) return "--";
        return $"{_latestWeight.Weight:F1} kg";
    }

    private string FormatBmi()
    {
        if (_latestWeight is null || _latestWeight.Bmi == 0) return "--";
        return $"{_latestWeight.Bmi:F1}";
    }

    private string FormatActiveMinutes()
    {
        if (_activitySummary is null) return "--";
        var total = _activitySummary.FairlyActiveMinutes + _activitySummary.VeryActiveMinutes;
        return total.ToString("N0");
    }

    private string FormatHeartRate()
    {
        if (_activitySummary is null || _activitySummary.RestingHeartRate == 0) return "--";
        return _activitySummary.RestingHeartRate.ToString();
    }

    private string FormatProtein()
    {
        if (_foodSummary is null) return "--";
        return $"{_foodSummary.Protein:F0}g";
    }

    private string GetCalorieGoalText()
    {
        if (_activityGoals is null || _activityGoals.CaloriesOut == 0) return "";
        return $"Goal: {_activityGoals.CaloriesOut:N0}";
    }

    private string GetFoodGoalText()
    {
        if (_foodGoals is null || _foodGoals.Calories == 0) return "";
        return $"Goal: {_foodGoals.Calories:N0}";
    }

    private string GetActiveMinutesGoalText()
    {
        if (_activityGoals is null || _activityGoals.ActiveMinutes == 0) return "";
        return $"Goal: {_activityGoals.ActiveMinutes}";
    }

    private string GetFloorsGoalText()
    {
        if (_activityGoals is null || _activityGoals.Floors == 0) return "";
        return $"Goal: {_activityGoals.Floors}";
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;
        _cts.Cancel();
        _cts.Dispose();
        return ValueTask.CompletedTask;
    }
}
