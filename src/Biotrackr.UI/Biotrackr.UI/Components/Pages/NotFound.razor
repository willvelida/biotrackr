@page "/not-found"
@layout MainLayout
@inject NavigationManager NavigationManager

<PageTitle>Biotrackr - Not Found</PageTitle>

<RadzenStack AlignItems="AlignItems.Center" class="rz-py-5">
    <RadzenText TextStyle="TextStyle.H3" class="rz-color-secondary">404</RadzenText>
    <RadzenText TextStyle="TextStyle.H5">Page not found</RadzenText>
    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">
        The page you're looking for doesn't exist.
    </RadzenText>
    <RadzenButton Text="Back to Dashboard" ButtonStyle="ButtonStyle.Primary"
                  Click="@(() => NavigationManager.NavigateTo("/"))" class="rz-mt-3" />
</RadzenStack>