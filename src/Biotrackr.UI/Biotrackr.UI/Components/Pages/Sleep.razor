@page "/sleep"
@rendermode InteractiveServer
@inject IBiotrackrApiService ApiService

<PageTitle>Biotrackr - Sleep</PageTitle>

<h1>Sleep</h1>

<DatePicker SelectedDate="@_selectedDate" StartDate="@_startDate" EndDate="@_endDate" Mode="@_mode"
            OnSingleDateSelected="LoadByDate" OnDateRangeSelected="LoadByRange" />

<LoadingSpinner IsLoading="@_isLoading" Message="Loading sleep data..." />
<ErrorDisplay Message="@_errorMessage" />

@if (!_isLoading && _singleItem is not null && _mode == "date")
{
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <SummaryCard Title="Time Asleep" Value="@FormatMinutes(_singleItem.Sleep.Summary.TotalMinutesAsleep)" />
        </div>
        <div class="col-md-3 col-sm-6">
            <SummaryCard Title="Time in Bed" Value="@FormatMinutes(_singleItem.Sleep.Summary.TotalTimeInBed)" />
        </div>
        <div class="col-md-3 col-sm-6">
            <SummaryCard Title="Sleep Records" Value="@_singleItem.Sleep.Summary.TotalSleepRecords.ToString()" />
        </div>
        <div class="col-md-3 col-sm-6">
            <SummaryCard Title="Efficiency" Value="@GetEfficiency()" />
        </div>
    </div>

    @if (_singleItem.Sleep.Summary.Stages is not null)
    {
        <div class="card mb-4">
            <div class="card-header"><strong>Sleep Stages</strong></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3 col-sm-6">
                        <div class="text-center">
                            <div class="stage-bar stage-deep" style="height: @GetStageHeight(_singleItem.Sleep.Summary.Stages.Deep)px;"></div>
                            <div class="mt-2"><strong>Deep</strong></div>
                            <div>@FormatMinutes(_singleItem.Sleep.Summary.Stages.Deep)</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="text-center">
                            <div class="stage-bar stage-light" style="height: @GetStageHeight(_singleItem.Sleep.Summary.Stages.Light)px;"></div>
                            <div class="mt-2"><strong>Light</strong></div>
                            <div>@FormatMinutes(_singleItem.Sleep.Summary.Stages.Light)</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="text-center">
                            <div class="stage-bar stage-rem" style="height: @GetStageHeight(_singleItem.Sleep.Summary.Stages.Rem)px;"></div>
                            <div class="mt-2"><strong>REM</strong></div>
                            <div>@FormatMinutes(_singleItem.Sleep.Summary.Stages.Rem)</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6">
                        <div class="text-center">
                            <div class="stage-bar stage-wake" style="height: @GetStageHeight(_singleItem.Sleep.Summary.Stages.Wake)px;"></div>
                            <div class="mt-2"><strong>Awake</strong></div>
                            <div>@FormatMinutes(_singleItem.Sleep.Summary.Stages.Wake)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_singleItem.Sleep.Sleep.Any())
    {
        <div class="card mb-4">
            <div class="card-header"><strong>Sleep Logs</strong></div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Start</th>
                                <th>End</th>
                                <th>Duration</th>
                                <th>Asleep</th>
                                <th>Awake</th>
                                <th>Efficiency</th>
                                <th>Type</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var record in _singleItem.Sleep.Sleep)
                            {
                                <tr>
                                    <td>@record.StartTime.ToString("HH:mm")</td>
                                    <td>@record.EndTime.ToString("HH:mm")</td>
                                    <td>@FormatMinutes(record.TimeInBed)</td>
                                    <td>@FormatMinutes(record.MinutesAsleep)</td>
                                    <td>@FormatMinutes(record.MinutesAwake)</td>
                                    <td>@record.Efficiency%</td>
                                    <td><span class="badge @(record.IsMainSleep ? "bg-primary" : "bg-secondary")">@(record.IsMainSleep ? "Main" : "Nap")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@if (!_isLoading && _rangeItems is not null && _mode == "range")
{
    <div class="card mb-4">
        <div class="card-header"><strong>Sleep Records</strong></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Time Asleep</th>
                            <th>Time in Bed</th>
                            <th>Records</th>
                            <th>Deep</th>
                            <th>Light</th>
                            <th>REM</th>
                            <th>Awake</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _rangeItems.Items)
                        {
                            <tr>
                                <td>@item.Date</td>
                                <td>@FormatMinutes(item.Sleep.Summary.TotalMinutesAsleep)</td>
                                <td>@FormatMinutes(item.Sleep.Summary.TotalTimeInBed)</td>
                                <td>@item.Sleep.Summary.TotalSleepRecords</td>
                                <td>@FormatMinutes(item.Sleep.Summary.Stages?.Deep ?? 0)</td>
                                <td>@FormatMinutes(item.Sleep.Summary.Stages?.Light ?? 0)</td>
                                <td>@FormatMinutes(item.Sleep.Summary.Stages?.Rem ?? 0)</td>
                                <td>@FormatMinutes(item.Sleep.Summary.Stages?.Wake ?? 0)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <PaginationControls PageNumber="@_rangeItems.PageNumber" TotalPages="@_rangeItems.TotalPages"
                        TotalCount="@_rangeItems.TotalCount" HasPreviousPage="@_rangeItems.HasPreviousPage"
                        HasNextPage="@_rangeItems.HasNextPage" OnPageChanged="OnPageChanged" />
}

@if (!_isLoading && _singleItem is null && _mode == "date" && _errorMessage is null)
{
    <div class="alert alert-info">No sleep data found for @_selectedDate.</div>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _mode = "date";
    private string _selectedDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private string _startDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-8)).ToString("yyyy-MM-dd");
    private string _endDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private int _currentPage = 1;

    private SleepItem? _singleItem;
    private PaginatedResponse<SleepItem>? _rangeItems;

    protected override async Task OnInitializedAsync()
    {
        await LoadByDate(_selectedDate);
    }

    private async Task LoadByDate(string date)
    {
        _mode = "date";
        _selectedDate = date;
        _isLoading = true;
        _errorMessage = null;
        _singleItem = null;

        try
        {
            _singleItem = await ApiService.GetSleepByDateAsync(date);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load sleep data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadByRange((string StartDate, string EndDate) range)
    {
        _mode = "range";
        _startDate = range.StartDate;
        _endDate = range.EndDate;
        _currentPage = 1;
        await LoadRangePage();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadRangePage();
    }

    private async Task LoadRangePage()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _rangeItems = await ApiService.GetSleepByDateRangeAsync(_startDate, _endDate, _currentPage);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load sleep data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string FormatMinutes(int minutes)
    {
        if (minutes == 0) return "--";
        var h = minutes / 60;
        var m = minutes % 60;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }

    private string GetEfficiency()
    {
        var mainSleep = _singleItem?.Sleep.Sleep.FirstOrDefault(s => s.IsMainSleep);
        return mainSleep is not null ? $"{mainSleep.Efficiency}%" : "--";
    }

    private int GetStageHeight(int minutes)
    {
        if (_singleItem?.Sleep.Summary.Stages is null) return 20;
        var max = Math.Max(1, new[] {
            _singleItem.Sleep.Summary.Stages.Deep,
            _singleItem.Sleep.Summary.Stages.Light,
            _singleItem.Sleep.Summary.Stages.Rem,
            _singleItem.Sleep.Summary.Stages.Wake
        }.Max());
        return (int)((double)minutes / max * 100) + 20;
    }
}
