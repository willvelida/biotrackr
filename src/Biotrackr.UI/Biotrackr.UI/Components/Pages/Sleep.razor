@page "/sleep"
@rendermode InteractiveServer
@inherits DataPageBase<SleepItem, SleepItem>

<PageTitle>Biotrackr - Sleep</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Sleep</RadzenText>

<DatePicker SelectedDate="@SelectedDate" StartDate="@StartDate" EndDate="@EndDate" Mode="@Mode"
            OnSingleDateSelected="LoadByDate" OnDateRangeSelected="LoadByRange" />

<LoadingSpinner IsLoading="@IsLoading" Message="Loading sleep data..." />
<ErrorDisplay Message="@ErrorMessage" />

@if (!IsLoading && SingleItem is not null && Mode == "date")
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Time Asleep" Value="@FormatMinutes(SingleItem.Sleep.Summary.TotalMinutesAsleep)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Time in Bed" Value="@FormatMinutes(SingleItem.Sleep.Summary.TotalTimeInBed)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Sleep Records" Value="@SingleItem.Sleep.Summary.TotalSleepRecords.ToString()" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Efficiency" Value="@GetEfficiency()" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem" class="rz-mb-4" AlignItems="AlignItems.Center">
        @if (SingleItem.Sleep.Summary.Stages is not null)
        {
            <RadzenColumn Size="12" SizeMD="6" SizeSM="12">
                <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Stages</RadzenText>
                <figure role="group" aria-label="Sleep stages chart">
                    <RadzenChart class="bt-chart">
                        <RadzenDonutSeries Data="@GetSleepStagesData()" CategoryProperty="Stage"
                            ValueProperty="Minutes" Title="Sleep Stages" />
                    </RadzenChart>
                    <figcaption class="sr-only">Donut chart showing the proportion of time spent in each sleep stage.</figcaption>
                </figure>
            </RadzenColumn>
        }
        <RadzenColumn Size="12" SizeMD="6" SizeSM="12">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Efficiency</RadzenText>
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Subtitle2">@($"{GetEfficiencyValue():F0}%")</RadzenText>
                <RadzenProgressBar Value="@GetEfficiencyValue()" ShowValue="false" Mode="ProgressBarMode.Determinate" Style="height: 20px;" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    @if (SingleItem.Sleep.Summary.Stages is not null)
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Stages</RadzenText>
        <RadzenRow Gap="1rem" class="rz-mb-4">
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <RadzenStack AlignItems="AlignItems.Center" @attributes='new Dictionary<string, object> { { "role", "group" }, { "aria-label", $"Deep sleep: {FormatMinutes(SingleItem.Sleep.Summary.Stages.Deep)}" } }'>
                    <div class="stage-bar stage-deep" style="height: @GetStageHeight(SingleItem.Sleep.Summary.Stages.Deep)px;" aria-hidden="true"></div>
                    <RadzenText TextStyle="TextStyle.Subtitle2">Deep</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@FormatMinutes(SingleItem.Sleep.Summary.Stages.Deep)</RadzenText>
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <RadzenStack AlignItems="AlignItems.Center" @attributes='new Dictionary<string, object> { { "role", "group" }, { "aria-label", $"Light sleep: {FormatMinutes(SingleItem.Sleep.Summary.Stages.Light)}" } }'>
                    <div class="stage-bar stage-light" style="height: @GetStageHeight(SingleItem.Sleep.Summary.Stages.Light)px;" aria-hidden="true"></div>
                    <RadzenText TextStyle="TextStyle.Subtitle2">Light</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@FormatMinutes(SingleItem.Sleep.Summary.Stages.Light)</RadzenText>
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <RadzenStack AlignItems="AlignItems.Center" @attributes='new Dictionary<string, object> { { "role", "group" }, { "aria-label", $"REM sleep: {FormatMinutes(SingleItem.Sleep.Summary.Stages.Rem)}" } }'>
                    <div class="stage-bar stage-rem" style="height: @GetStageHeight(SingleItem.Sleep.Summary.Stages.Rem)px;" aria-hidden="true"></div>
                    <RadzenText TextStyle="TextStyle.Subtitle2">REM</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@FormatMinutes(SingleItem.Sleep.Summary.Stages.Rem)</RadzenText>
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <RadzenStack AlignItems="AlignItems.Center" @attributes='new Dictionary<string, object> { { "role", "group" }, { "aria-label", $"Awake: {FormatMinutes(SingleItem.Sleep.Summary.Stages.Wake)}" } }'>
                    <div class="stage-bar stage-wake" style="height: @GetStageHeight(SingleItem.Sleep.Summary.Stages.Wake)px;" aria-hidden="true"></div>
                    <RadzenText TextStyle="TextStyle.Subtitle2">Awake</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@FormatMinutes(SingleItem.Sleep.Summary.Stages.Wake)</RadzenText>
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    }

    @if (_hypnogramData is not null && _hypnogramData.Any())
    {
        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-2">Sleep Timeline</RadzenText>
        <figure role="group" aria-label="Sleep timeline chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenAreaSeries Data="@_hypnogramData" CategoryProperty="Time" ValueProperty="Level"
                    Smooth="false" StrokeWidth="1" Title="Sleep Stage" />
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis Min="0" Max="3">
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Area chart showing sleep stage transitions throughout the night.</figcaption>
        </figure>
    }

    @if (SingleItem.Sleep.Sleep.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Logs</RadzenText>
        <RadzenDataGrid Data="@SingleItem.Sleep.Sleep" TItem="SleepRecord" Density="Density.Compact" AllowPaging="false" Responsive="true" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Start">
                    <Template Context="record">@record.StartTime.ToString("HH:mm")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="End">
                    <Template Context="record">@record.EndTime.ToString("HH:mm")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Duration">
                    <Template Context="record">@FormatMinutes(record.TimeInBed)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Asleep">
                    <Template Context="record">@FormatMinutes(record.MinutesAsleep)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Awake">
                    <Template Context="record">@FormatMinutes(record.MinutesAwake)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Efficiency">
                    <Template Context="record">@record.Efficiency%</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Type">
                    <Template Context="record">
                        <RadzenBadge Text="@(record.IsMainSleep ? "Main" : "Nap")" BadgeStyle="@(record.IsMainSleep ? BadgeStyle.Primary : BadgeStyle.Secondary)" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
}

@if (!IsLoading && RangeItems is not null && Mode == "range")
{
    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="Charts">
    @if (RangeItems.Items.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Duration Over Time</RadzenText>
        <figure role="group" aria-label="Sleep duration over time chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenLineSeries Data="@GetRangeDurationData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Hours Asleep" Smooth="true" />
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Line chart showing daily sleep duration trend. See the Table tab for exact values.</figcaption>
        </figure>

        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Efficiency Over Time</RadzenText>
        <figure role="group" aria-label="Sleep efficiency over time chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenLineSeries Data="@GetRangeEfficiencyData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Efficiency %" Smooth="true" />
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Line chart showing daily sleep efficiency percentage trend. See the Table tab for exact values.</figcaption>
        </figure>

        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Stages Over Time</RadzenText>
        <figure role="group" aria-label="Sleep stages over time chart">
            <RadzenChart class="bt-chart rz-mb-4">
                <RadzenAreaSeries Data="@GetRangeDeepData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Deep" Smooth="true" />
                <RadzenAreaSeries Data="@GetRangeLightData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Light" Smooth="true" />
                <RadzenAreaSeries Data="@GetRangeRemData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="REM" Smooth="true" />
                <RadzenAreaSeries Data="@GetRangeWakeData()" CategoryProperty="Date" ValueProperty="Value"
                    Title="Awake" Smooth="true" />
                <RadzenCategoryAxis Padding="20" />
                <RadzenValueAxis>
                    <RadzenGridLines Visible="true" />
                </RadzenValueAxis>
            </RadzenChart>
            <figcaption class="sr-only">Stacked area chart showing deep, light, REM, and awake minutes over time. See the Table tab for exact values.</figcaption>
        </figure>
    }
            </RadzenTabsItem>
            <RadzenTabsItem Text="Table">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Records</RadzenText>
    <RadzenDataGrid Data="@RangeItems.Items" TItem="SleepItem" Density="Density.Compact"
                    AllowPaging="true" PageSize="10" Count="@RangeItems.TotalCount" LoadData="@OnLoadData" Responsive="true" class="rz-mb-4">
        <Columns>
            <RadzenDataGridColumn TItem="SleepItem" Property="Date" Title="Date" />
            <RadzenDataGridColumn TItem="SleepItem" Title="Time Asleep">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.TotalMinutesAsleep)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Time in Bed">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.TotalTimeInBed)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Records">
                <Template Context="item">@item.Sleep.Summary.TotalSleepRecords</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Deep">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.Stages?.Deep ?? 0)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Light">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.Stages?.Light ?? 0)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="REM">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.Stages?.Rem ?? 0)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Awake">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.Stages?.Wake ?? 0)</Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
}

@if (!IsLoading && SingleItem is null && Mode == "date" && ErrorMessage is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">No sleep data found for @SelectedDate.</RadzenAlert>
}

@code {
    private List<HypnogramPoint>? _hypnogramData;

    private record HypnogramPoint(string Time, int Level);

    protected override string DataName => "sleep";

    protected override Task<SleepItem?> FetchSingleAsync(string date)
        => ApiService.GetSleepByDateAsync(date);

    protected override Task<PaginatedResponse<SleepItem>> FetchRangeAsync(string start, string end, int page)
        => ApiService.GetSleepByDateRangeAsync(start, end, page);

    protected new async Task LoadByDate(string date)
    {
        await base.LoadByDate(date);
        _hypnogramData = null;

        var mainSleep = SingleItem?.Sleep?.Sleep?.FirstOrDefault(r => r.IsMainSleep);
        if (mainSleep?.Levels?.Data is { Count: > 0 })
        {
            _hypnogramData = mainSleep.Levels.Data
                .OrderBy(d => d.DateTime)
                .Select(d => new HypnogramPoint(
                    d.DateTime.ToString("HH:mm"),
                    d.Level switch { "wake" => 3, "rem" => 2, "light" => 1, "deep" => 0, _ => 0 }))
                .ToList();
        }
    }

    private static string FormatMinutes(int minutes)
    {
        if (minutes == 0) return "--";
        var h = minutes / 60;
        var m = minutes % 60;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }

    private string GetEfficiency()
    {
        var mainSleep = SingleItem?.Sleep.Sleep.FirstOrDefault(s => s.IsMainSleep);
        return mainSleep is not null ? $"{mainSleep.Efficiency}%" : "--";
    }

    private double GetEfficiencyValue()
    {
        var mainSleep = SingleItem?.Sleep.Sleep.FirstOrDefault(s => s.IsMainSleep);
        return mainSleep?.Efficiency ?? 0;
    }

    private record SleepStageDataPoint(string Stage, int Minutes);

    private List<SleepStageDataPoint> GetSleepStagesData()
    {
        var stages = SingleItem!.Sleep.Summary.Stages;
        return
        [
            new("Deep", stages.Deep),
            new("Light", stages.Light),
            new("REM", stages.Rem),
            new("Awake", stages.Wake)
        ];
    }

    private record ChartDataPoint(string Date, double Value);

    private List<ChartDataPoint> GetRangeDurationData() =>
        RangeItems!.Items.Select(s => new ChartDataPoint(s.Date, Math.Round(s.Sleep.Summary.TotalMinutesAsleep / 60.0, 1))).ToList();

    private List<ChartDataPoint> GetRangeEfficiencyData() =>
        RangeItems!.Items
            .Where(s => s.Sleep.Sleep.Any(r => r.IsMainSleep))
            .Select(s => new ChartDataPoint(s.Date, s.Sleep.Sleep.First(r => r.IsMainSleep).Efficiency)).ToList();

    private List<ChartDataPoint> GetRangeDeepData() =>
        RangeItems!.Items.Select(s => new ChartDataPoint(s.Date, s.Sleep.Summary.Stages?.Deep ?? 0)).ToList();

    private List<ChartDataPoint> GetRangeLightData() =>
        RangeItems!.Items.Select(s => new ChartDataPoint(s.Date, s.Sleep.Summary.Stages?.Light ?? 0)).ToList();

    private List<ChartDataPoint> GetRangeRemData() =>
        RangeItems!.Items.Select(s => new ChartDataPoint(s.Date, s.Sleep.Summary.Stages?.Rem ?? 0)).ToList();

    private List<ChartDataPoint> GetRangeWakeData() =>
        RangeItems!.Items.Select(s => new ChartDataPoint(s.Date, s.Sleep.Summary.Stages?.Wake ?? 0)).ToList();

    private int GetStageHeight(int minutes)
    {
        if (SingleItem?.Sleep.Summary.Stages is null) return 20;
        var max = Math.Max(1, new[] {
            SingleItem.Sleep.Summary.Stages.Deep,
            SingleItem.Sleep.Summary.Stages.Light,
            SingleItem.Sleep.Summary.Stages.Rem,
            SingleItem.Sleep.Summary.Stages.Wake
        }.Max());
        return (int)((double)minutes / max * 100) + 20;
    }
}
