@page "/sleep"
@rendermode InteractiveServer
@inject IBiotrackrApiService ApiService

<PageTitle>Biotrackr - Sleep</PageTitle>

<RadzenText TextStyle="TextStyle.H4">Sleep</RadzenText>

<DatePicker SelectedDate="@_selectedDate" StartDate="@_startDate" EndDate="@_endDate" Mode="@_mode"
            OnSingleDateSelected="LoadByDate" OnDateRangeSelected="LoadByRange" />

<LoadingSpinner IsLoading="@_isLoading" Message="Loading sleep data..." />
<ErrorDisplay Message="@_errorMessage" />

@if (!_isLoading && _singleItem is not null && _mode == "date")
{
    <RadzenRow Gap="1rem" class="rz-mb-4">
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Time Asleep" Value="@FormatMinutes(_singleItem.Sleep.Summary.TotalMinutesAsleep)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Time in Bed" Value="@FormatMinutes(_singleItem.Sleep.Summary.TotalTimeInBed)" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Sleep Records" Value="@_singleItem.Sleep.Summary.TotalSleepRecords.ToString()" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
            <SummaryCard Title="Efficiency" Value="@GetEfficiency()" />
        </RadzenColumn>
    </RadzenRow>

    @if (_singleItem.Sleep.Summary.Stages is not null)
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Stages</RadzenText>
        <RadzenRow Gap="1rem" class="rz-mb-4">
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <RadzenStack AlignItems="AlignItems.Center">
                    <div class="stage-bar stage-deep" style="height: @GetStageHeight(_singleItem.Sleep.Summary.Stages.Deep)px;"></div>
                    <RadzenText TextStyle="TextStyle.Subtitle2">Deep</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@FormatMinutes(_singleItem.Sleep.Summary.Stages.Deep)</RadzenText>
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <RadzenStack AlignItems="AlignItems.Center">
                    <div class="stage-bar stage-light" style="height: @GetStageHeight(_singleItem.Sleep.Summary.Stages.Light)px;"></div>
                    <RadzenText TextStyle="TextStyle.Subtitle2">Light</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@FormatMinutes(_singleItem.Sleep.Summary.Stages.Light)</RadzenText>
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <RadzenStack AlignItems="AlignItems.Center">
                    <div class="stage-bar stage-rem" style="height: @GetStageHeight(_singleItem.Sleep.Summary.Stages.Rem)px;"></div>
                    <RadzenText TextStyle="TextStyle.Subtitle2">REM</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@FormatMinutes(_singleItem.Sleep.Summary.Stages.Rem)</RadzenText>
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="3" SizeSM="6">
                <RadzenStack AlignItems="AlignItems.Center">
                    <div class="stage-bar stage-wake" style="height: @GetStageHeight(_singleItem.Sleep.Summary.Stages.Wake)px;"></div>
                    <RadzenText TextStyle="TextStyle.Subtitle2">Awake</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@FormatMinutes(_singleItem.Sleep.Summary.Stages.Wake)</RadzenText>
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    }

    @if (_singleItem.Sleep.Sleep.Any())
    {
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Logs</RadzenText>
        <RadzenDataGrid Data="@_singleItem.Sleep.Sleep" TItem="SleepRecord" Density="Density.Compact" AllowPaging="false" class="rz-mb-4">
            <Columns>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Start">
                    <Template Context="record">@record.StartTime.ToString("HH:mm")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="End">
                    <Template Context="record">@record.EndTime.ToString("HH:mm")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Duration">
                    <Template Context="record">@FormatMinutes(record.TimeInBed)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Asleep">
                    <Template Context="record">@FormatMinutes(record.MinutesAsleep)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Awake">
                    <Template Context="record">@FormatMinutes(record.MinutesAwake)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Efficiency">
                    <Template Context="record">@record.Efficiency%</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SleepRecord" Title="Type">
                    <Template Context="record">
                        <RadzenBadge Text="@(record.IsMainSleep ? "Main" : "Nap")" BadgeStyle="@(record.IsMainSleep ? BadgeStyle.Primary : BadgeStyle.Secondary)" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
}

@if (!_isLoading && _rangeItems is not null && _mode == "range")
{
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Sleep Records</RadzenText>
    <RadzenDataGrid Data="@_rangeItems.Items" TItem="SleepItem" Density="Density.Compact"
                    AllowPaging="true" PageSize="10" Count="@_rangeItems.TotalCount" LoadData="@OnLoadData" class="rz-mb-4">
        <Columns>
            <RadzenDataGridColumn TItem="SleepItem" Property="Date" Title="Date" />
            <RadzenDataGridColumn TItem="SleepItem" Title="Time Asleep">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.TotalMinutesAsleep)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Time in Bed">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.TotalTimeInBed)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Records">
                <Template Context="item">@item.Sleep.Summary.TotalSleepRecords</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Deep">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.Stages?.Deep ?? 0)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Light">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.Stages?.Light ?? 0)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="REM">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.Stages?.Rem ?? 0)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SleepItem" Title="Awake">
                <Template Context="item">@FormatMinutes(item.Sleep.Summary.Stages?.Wake ?? 0)</Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@if (!_isLoading && _singleItem is null && _mode == "date" && _errorMessage is null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">No sleep data found for @_selectedDate.</RadzenAlert>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _mode = "date";
    private string _selectedDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private string _startDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-8)).ToString("yyyy-MM-dd");
    private string _endDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
    private int _currentPage = 1;

    private SleepItem? _singleItem;
    private PaginatedResponse<SleepItem>? _rangeItems;

    protected override async Task OnInitializedAsync()
    {
        await LoadByDate(_selectedDate);
    }

    private async Task LoadByDate(string date)
    {
        _mode = "date";
        _selectedDate = date;
        _isLoading = true;
        _errorMessage = null;
        _singleItem = null;

        try
        {
            _singleItem = await ApiService.GetSleepByDateAsync(date);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load sleep data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadByRange((string StartDate, string EndDate) range)
    {
        _mode = "range";
        _startDate = range.StartDate;
        _endDate = range.EndDate;
        _currentPage = 1;
        await LoadRangePage();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadRangePage();
    }

    private async Task LoadRangePage()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _rangeItems = await ApiService.GetSleepByDateRangeAsync(_startDate, _endDate, _currentPage);
        }
        catch (Exception)
        {
            _errorMessage = "Failed to load sleep data. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnLoadData(LoadDataArgs args)
    {
        _currentPage = (int)((args.Skip ?? 0) / 10) + 1;
        await LoadRangePage();
    }

    private static string FormatMinutes(int minutes)
    {
        if (minutes == 0) return "--";
        var h = minutes / 60;
        var m = minutes % 60;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }

    private string GetEfficiency()
    {
        var mainSleep = _singleItem?.Sleep.Sleep.FirstOrDefault(s => s.IsMainSleep);
        return mainSleep is not null ? $"{mainSleep.Efficiency}%" : "--";
    }

    private int GetStageHeight(int minutes)
    {
        if (_singleItem?.Sleep.Summary.Stages is null) return 20;
        var max = Math.Max(1, new[] {
            _singleItem.Sleep.Summary.Stages.Deep,
            _singleItem.Sleep.Summary.Stages.Light,
            _singleItem.Sleep.Summary.Stages.Rem,
            _singleItem.Sleep.Summary.Stages.Wake
        }.Max());
        return (int)((double)minutes / max * 100) + 20;
    }
}
