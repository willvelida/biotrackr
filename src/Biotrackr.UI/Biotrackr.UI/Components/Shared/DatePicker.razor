<RadzenCard class="rz-mb-3">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Wrap="FlexWrap.Wrap">
        <RadzenSelectBar @bind-Value="Mode" TValue="string" Change="@(args => OnModeChanged(args))">
            <Items>
                <RadzenSelectBarItem Text="Single Date" Value="@("date")" />
                <RadzenSelectBarItem Text="Date Range" Value="@("range")" />
            </Items>
        </RadzenSelectBar>

        @if (Mode == "date")
        {
            <RadzenFormField Text="Date">
                <ChildContent>
                    <RadzenDatePicker @bind-Value="_singleDate" DateFormat="yyyy-MM-dd"
                                      Change="@(args => OnDateChanged(args))" Name="single-date" />
                </ChildContent>
            </RadzenFormField>
        }
        else
        {
            <RadzenFormField Text="Start">
                <ChildContent>
                    <RadzenDatePicker @bind-Value="_startDateValue" DateFormat="yyyy-MM-dd" Name="start-date" />
                </ChildContent>
            </RadzenFormField>
            <RadzenFormField Text="End">
                <ChildContent>
                    <RadzenDatePicker @bind-Value="_endDateValue" DateFormat="yyyy-MM-dd" Name="end-date" />
                </ChildContent>
            </RadzenFormField>
            <RadzenButton Text="Apply" Click="ApplyRange" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" />
        }

        <RadzenButton Text="Yesterday" Click="GoToToday" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" />
    </RadzenStack>
</RadzenCard>

@code {
    [Parameter]
    public string SelectedDate { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");

    [Parameter]
    public string StartDate { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(-8)).ToString("yyyy-MM-dd");

    [Parameter]
    public string EndDate { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");

    [Parameter]
    public string Mode { get; set; } = "date";

    [Parameter]
    public EventCallback<string> OnSingleDateSelected { get; set; }

    [Parameter]
    public EventCallback<(string StartDate, string EndDate)> OnDateRangeSelected { get; set; }

    private DateTime? _singleDate;
    private DateTime? _startDateValue;
    private DateTime? _endDateValue;

    protected override void OnParametersSet()
    {
        if (DateTime.TryParse(SelectedDate, out var d)) _singleDate = d;
        if (DateTime.TryParse(StartDate, out var s)) _startDateValue = s;
        if (DateTime.TryParse(EndDate, out var e)) _endDateValue = e;
    }

    private void OnModeChanged(object value)
    {
        StateHasChanged();
    }

    private async Task OnDateChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            SelectedDate = value.Value.ToString("yyyy-MM-dd");
            await OnSingleDateSelected.InvokeAsync(SelectedDate);
        }
    }

    private async Task ApplyRange()
    {
        if (_startDateValue.HasValue) StartDate = _startDateValue.Value.ToString("yyyy-MM-dd");
        if (_endDateValue.HasValue) EndDate = _endDateValue.Value.ToString("yyyy-MM-dd");
        await OnDateRangeSelected.InvokeAsync((StartDate, EndDate));
    }

    private async Task GoToToday()
    {
        var yesterday = DateOnly.FromDateTime(DateTime.Today.AddDays(-1)).ToString("yyyy-MM-dd");
        SelectedDate = yesterday;
        _singleDate = DateTime.Today.AddDays(-1);
        StartDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-8)).ToString("yyyy-MM-dd");
        _startDateValue = DateTime.Today.AddDays(-8);
        EndDate = yesterday;
        _endDateValue = DateTime.Today.AddDays(-1);

        if (Mode == "date")
        {
            await OnSingleDateSelected.InvokeAsync(yesterday);
        }
        else
        {
            await OnDateRangeSelected.InvokeAsync((StartDate, EndDate));
        }
    }
}
