# Auto detect text files and normalize line endings
* text=auto eol=lf

# Force specific file types
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.bicep text eol=lf
*.razor text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.runsettings text eol=lf
Dockerfile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.excalidraw binary
